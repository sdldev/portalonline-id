---
import Layout from "./Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "../utils/collections";
import { slugify } from "../utils/slugify";
import "../styles/prose.css";

export interface Props {
    title: string;
    description: string;
    date: Date;
    author: string;
    category: string;
    tags: string[];
    image?: string;
    imageCaption?: string;
    headings?: import("astro").MarkdownHeading[];
}

const {
    title,
    description,
    date,
    author,
    category,
    tags,
    image,
    imageCaption,
    headings = [],
} = Astro.props;

const allTutorials = await getCollection("tutorial");
const allArticles = await getCollection("article");
const allTips = await getCollection("tips");
const allUpdates = await getCollection("update");
const allAuthors = await getCollection("author");

const authorProfile = allAuthors.find((item) => item.data.name === author);
const allItems = [...allTutorials, ...allArticles, ...allTips, ...allUpdates];

const relatedArticles = allItems
    .filter((item) => item.data.category === category && item.data.title !== title)
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
    .slice(0, 3);

const latestArticles = allItems
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
    .slice(0, 5);

const formattedDate = new Date(date).toLocaleDateString("id-ID", {
    year: "numeric",
    month: "long",
    day: "numeric",
});

const authorHref = `/author/${authorProfile ? authorProfile.id : author.toLowerCase().replace(/\s+/g, "-")}`;
const pathSegments = Astro.url.pathname.split("/").filter(Boolean);
const rawCollection = pathSegments[0] ?? "article";
const collectionSlug = ["article", "tips", "tutorial", "update"].includes(rawCollection)
    ? rawCollection
    : "article";
const categoryHref = `/${collectionSlug}/`;
---

<Layout
    title={`${title} | Portal Online`}
    description={description}
    image={image}
    canonical={Astro.url.href}
    openGraph={{
        basic: {
            title: `${title} | Portal Online`,
            type: "article",
            image: image ?? "https://portalonline.id/og-default.png",
            url: Astro.url.href,
        },
        optional: {
            description,
            locale: "id_ID",
            siteName: "Portal Online",
        },
        article: {
            publishedTime: new Date(date).toISOString(),
            modifiedTime: new Date(date).toISOString(),
            authors: [author],
            section: category,
            tags,
        },
        image: {
            url: image ?? "https://portalonline.id/og-default.png",
            alt: title,
            width: 1200,
            height: 630,
        },
    }}
    twitter={{
        card: "summary_large_image",
        site: "@portalonlineid",
        creator: `@${author.toLowerCase().replace(/\s+/g, "")}`,
    }}
>
    <Navbar />

    <main id="main-content" class="doc-page">
        <section class="doc-hero section-frame">
            <div class="container doc-hero-inner">
                <nav aria-label="Breadcrumb" class="doc-breadcrumb">
                    <a href="/">Beranda</a>
                    <span>/</span>
                    <a href={categoryHref}>{category}</a>
                    <span>/</span>
                    <span aria-current="page">{title}</span>
                </nav>

                <p class="eyebrow">Publikasi</p>
                <h1 class="doc-title font-display">{title}</h1>
                <p class="doc-description">{description}</p>

                <div class="doc-meta">
                    <time>{formattedDate}</time>
                    <span>·</span>
                    <a href={authorHref}>{author}</a>
                </div>

                {
                    tags.length > 0 && (
                        <div class="doc-tags">
                            {tags.map((tag) => (
                                <a href={`/tags/${slugify(tag)}/`} class="doc-tag">#{tag}</a>
                            ))}
                        </div>
                    )
                }
            </div>
        </section>

        <section class="section doc-content-wrap">
            <div class="container doc-grid">
                <article class="doc-main">
                    {
                        image && (
                            <figure class="doc-cover">
                                <img src={image} alt={title} loading="eager" />
                                {imageCaption && <figcaption>{imageCaption}</figcaption>}
                            </figure>
                        )
                    }

                    <div class={`prose${image ? " prose-after-cover" : ""}`}>
                        <slot />
                    </div>

                    <section class="doc-inline-cta" aria-labelledby="doc-inline-cta-title">
                        <div class="doc-inline-cta-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" role="img" focusable="false">
                                <path
                                    fill="currentColor"
                                    d="M19.05 4.91A9.82 9.82 0 0 0 12.03 2 9.95 9.95 0 0 0 3.4 16.9L2 22l5.24-1.37A9.94 9.94 0 0 0 12 22h.03A9.99 9.99 0 0 0 22 12.04a9.83 9.83 0 0 0-2.95-7.13Zm-7.02 15.4h-.02a8.2 8.2 0 0 1-4.17-1.13l-.3-.17-3.11.81.83-3.03-.2-.31a8.25 8.25 0 0 1 1.27-10.42 8.26 8.26 0 0 1 5.88-2.43 8.25 8.25 0 0 1 8.23 8.24 8.32 8.32 0 0 1-8.41 8.44Zm4.53-6.16c-.25-.13-1.47-.73-1.7-.81-.23-.08-.4-.13-.57.13-.17.25-.66.81-.81.98-.15.17-.3.19-.55.06-.25-.13-1.06-.39-2.01-1.24-.74-.66-1.24-1.48-1.39-1.73-.15-.25-.02-.39.11-.52.12-.12.25-.3.38-.45.13-.15.17-.25.25-.42.08-.17.04-.32-.02-.45-.06-.13-.57-1.37-.78-1.88-.21-.5-.42-.43-.57-.44h-.49c-.17 0-.45.06-.68.32-.23.25-.87.85-.87 2.07 0 1.22.89 2.4 1.01 2.57.13.17 1.76 2.69 4.27 3.77.6.26 1.06.42 1.42.54.6.19 1.15.16 1.58.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.08.15-1.18-.06-.1-.23-.16-.48-.29Z"
                                />
                            </svg>
                        </div>

                        <div class="doc-inline-cta-copy">
                            <p class="doc-inline-cta-eyebrow">Butuh Bantuan Lebih Lanjut?</p>
                            <h2 id="doc-inline-cta-title">Konsultasi Gratis via WhatsApp</h2>
                            <p>
                                Tim kami siap membantu Anda membangun portal berita online yang profesional dan
                                SEO-friendly. Hubungi kami sekarang — respons cepat!
                            </p>
                        </div>

                        <a
                            class="doc-inline-cta-button"
                            href="https://wa.me/6285783024799?text=Hallo%2C%20Saya%20baru%20saja%20mengunjungi%20website%20Portal%20Online%2C%20Saya%20ingin%20diskusi%20lebih%20detail%20tentang%20CMS%20PORTAL%20ONLINE"
                            target="_blank"
                            rel="nofollow noopener noreferrer"
                        >
                            Chat Sekarang
                        </a>
                    </section>
                </article>

                <aside class="doc-sidebar">
                    {
                        headings.length > 0 && (
                            <section class="sidebar-card">
                                <h2 class="sidebar-title">Daftar Isi</h2>
                                <ol class="toc-list">
                                    {headings.filter((item) => item.depth <= 3).map((heading) => (
                                        <li class={`toc-depth-${heading.depth}`}>
                                            <a href={`#${heading.slug}`}>{heading.text}</a>
                                        </li>
                                    ))}
                                </ol>
                            </section>
                        )
                    }

                    <section class="sidebar-card">
                        <h2 class="sidebar-title">Artikel Terbaru</h2>
                        <ul class="sidebar-list">
                            {latestArticles.map((item) => (
                                <li>
                                    <a href={`/${item.collection}/${item.id}`}>{item.data.title}</a>
                                </li>
                            ))}
                        </ul>
                    </section>

                    {
                        relatedArticles.length > 0 && (
                            <section class="sidebar-card">
                                <h2 class="sidebar-title">Terkait</h2>
                                <ul class="sidebar-list">
                                    {relatedArticles.map((item) => (
                                        <li>
                                            <a href={`/${item.collection}/${item.id}`}>{item.data.title}</a>
                                        </li>
                                    ))}
                                </ul>
                            </section>
                        )
                    }
                </aside>
            </div>
        </section>
    </main>

    <Footer />
</Layout>

<style>
    .doc-page {
        padding-top: 80px;
    }

    .doc-hero {
        padding: 3.35rem 0 2.7rem;
        position: relative;
    }

    .doc-hero-inner {
        max-width: 66rem;
        display: grid;
        gap: 1rem;
    }

    .doc-breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        font-size: 0.76rem;
        color: var(--color-text-subtle);
        margin-bottom: 0.4rem;
        flex-wrap: wrap;
    }

    .eyebrow {
        font-size: 0.76rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--color-text-soft);
        margin-bottom: 0.2rem;
    }

    .doc-breadcrumb a:hover {
        color: var(--color-text);
    }

    .doc-title {
        font-size: clamp(2.7rem, 6.4vw, 5.2rem);
        line-height: 1.02;
        letter-spacing: -0.02em;
        max-width: 11.4ch;
        text-wrap: balance;
    }

    .doc-description {
        max-width: 62ch;
        color: var(--color-text-muted);
        line-height: 1.64;
        font-size: clamp(1.04rem, 1.18vw, 1.22rem);
    }

    .doc-meta {
        display: flex;
        align-items: center;
        gap: 0.48rem;
        color: var(--color-text-soft);
        font-size: 0.9rem;
    }

    .doc-meta a:hover {
        color: var(--color-text);
    }

    .doc-meta a:focus-visible,
    .doc-tag:focus-visible,
    .toc-list a:focus-visible,
    .sidebar-list a:focus-visible {
        outline: 2px solid rgba(var(--color-primary), 0.85);
        outline-offset: 2px;
    }

    .doc-tags {
        margin-top: 0.45rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .doc-tag {
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 999px;
        padding: 0.3rem 0.66rem;
        font-size: 0.76rem;
        color: var(--color-text-soft);
        background: rgba(255, 255, 255, 0.02);
    }

    .doc-tag:hover {
        color: var(--color-text);
        border-color: rgba(255, 255, 255, 0.24);
    }

    .doc-grid {
        display: grid;
        gap: 1.75rem;
    }

    .doc-main {
        min-width: 0;
    }

    .doc-main :global(.prose) {
        max-width: min(86ch, 100%);
        line-height: 1.6;
        text-wrap: pretty;
    }

    .doc-main :global(.prose h2) {
        line-height: 1.04;
        text-wrap: balance;
    }

    .doc-cover {
        margin-bottom: 0;
    }

    .doc-cover img {
        width: 100%;
        display: block;
        border-radius: 0.8rem;
        border: 1px solid rgba(255, 255, 255, 0.14);
    }

    .doc-cover figcaption {
        margin-top: 0.24rem;
        margin-bottom: 0;
        color: var(--color-text-subtle);
        font-size: 0.74rem;
        font-style: normal;
        text-align: left;
        line-height: 1.35;
    }

    .doc-main :global(.prose-after-cover) {
        margin-top: 0;
    }

    .doc-main :global(.prose-after-cover > :first-child) {
        margin-top: 0.32rem;
        margin-block-start: 0.32rem;
        padding-top: 0;
        padding-block-start: 0;
    }

    .doc-inline-cta {
        margin-top: 2.4rem;
        border: 1px solid rgba(86, 173, 150, 0.34);
        border-radius: 1.12rem;
        background: radial-gradient(95% 140% at 0% 0%, rgba(26, 96, 86, 0.38) 0%, rgba(6, 18, 30, 0.96) 58%);
        box-shadow:
            inset 0 0 0 1px rgba(120, 204, 179, 0.1),
            0 16px 32px rgba(2, 8, 18, 0.28);
        padding: 1.2rem;
        display: grid;
        gap: 1rem;
        position: relative;
        overflow: hidden;
        transition:
            border-color var(--transition-fast),
            transform var(--transition-fast),
            box-shadow var(--transition-fast);
    }

    .doc-inline-cta::before,
    .doc-inline-cta::after {
        content: "";
        position: absolute;
        inset: auto;
        pointer-events: none;
        opacity: 0;
        transition: opacity var(--transition-fast), transform var(--transition-fast);
    }

    .doc-inline-cta::before {
        width: 220px;
        height: 220px;
        top: -95px;
        right: -80px;
        border-radius: 999px;
        background: radial-gradient(circle, rgba(117, 228, 186, 0.28) 0%, rgba(117, 228, 186, 0) 72%);
        transform: translate3d(8px, -8px, 0);
    }

    .doc-inline-cta::after {
        width: 120px;
        height: 120px;
        left: -44px;
        bottom: -46px;
        border-radius: 999px;
        background: radial-gradient(circle, rgba(79, 216, 170, 0.2) 0%, rgba(79, 216, 170, 0) 70%);
        transform: translate3d(-6px, 6px, 0);
    }

    .doc-inline-cta:hover,
    .doc-inline-cta:focus-within {
        border-color: rgba(128, 221, 189, 0.55);
        transform: translateY(-2px);
        box-shadow:
            inset 0 0 0 1px rgba(132, 227, 193, 0.14),
            0 22px 40px rgba(4, 12, 24, 0.34);
    }

    .doc-inline-cta:hover::before,
    .doc-inline-cta:hover::after,
    .doc-inline-cta:focus-within::before,
    .doc-inline-cta:focus-within::after {
        opacity: 1;
        transform: translate3d(0, 0, 0);
    }

    .doc-inline-cta-icon {
        width: 3rem;
        height: 3rem;
        flex: 0 0 3rem;
        overflow: hidden;
        border-radius: 999px;
        display: grid;
        place-items: center;
        color: #6ce8b6;
        border: 1px solid rgba(108, 232, 182, 0.44);
        background: rgba(69, 179, 143, 0.18);
    }

    .doc-inline-cta-icon svg {
        width: 1.65rem;
        height: 1.65rem;
        display: block;
        max-width: none;
    }

    .doc-inline-cta-copy {
        display: grid;
        gap: 0.34rem;
    }

    .doc-inline-cta-eyebrow {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #7be2bc;
        font-weight: 700;
    }

    .doc-inline-cta-copy h2 {
        margin: 0;
        font-size: clamp(1.18rem, 1.55vw, 1.46rem);
        line-height: 1.22;
        color: #eefaf5;
    }

    .doc-inline-cta-copy p {
        margin: 0;
        color: rgba(218, 235, 228, 0.92);
        font-size: 0.98rem;
        line-height: 1.5;
    }

    .doc-inline-cta-button {
        justify-self: start;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 2.6rem;
        padding: 0.62rem 1.1rem;
        border-radius: 999px;
        background: linear-gradient(180deg, #4fd8aa 0%, #2fb48b 100%);
        color: #06241b;
        font-weight: 700;
        font-size: 0.94rem;
        letter-spacing: 0.01em;
        border: 1px solid rgba(132, 235, 202, 0.78);
        box-shadow: 0 8px 18px rgba(47, 180, 139, 0.24);
    }

    .doc-inline-cta-button:hover {
        filter: brightness(1.05);
        transform: translateY(-1px);
    }

    .doc-inline-cta-button:focus-visible {
        outline: 2px solid rgba(57, 255, 145, 0.9);
        outline-offset: 2px;
    }

    .doc-sidebar {
        display: grid;
        gap: 0.9rem;
        align-content: start;
    }

    .sidebar-card {
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 0.9rem;
        padding: 0.95rem;
        background: rgba(255, 255, 255, 0.004);
    }

    .sidebar-title {
        font-size: 0.74rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-text-soft);
        margin-bottom: 0.65rem;
    }

    .toc-list,
    .sidebar-list {
        list-style: none;
        display: grid;
        gap: 0.45rem;
    }

    .toc-list a,
    .sidebar-list a {
        color: var(--color-text-muted);
        font-size: 0.9rem;
        line-height: 1.5;
    }

    .toc-list a:hover,
    .sidebar-list a:hover {
        color: var(--color-text);
    }

    .toc-depth-3 {
        padding-left: 0.8rem;
    }

    @media (min-width: 1040px) {
        .doc-grid {
            grid-template-columns: minmax(0, 1fr) 248px;
            gap: 1.2rem;
        }

        .doc-sidebar {
            position: sticky;
            top: 96px;
            max-height: calc(100svh - 100px);
            overflow-y: auto;
            padding-right: 0.1rem;
        }

        .doc-inline-cta {
            grid-template-columns: auto minmax(0, 1fr) auto;
            align-items: center;
            gap: 1.2rem;
            padding: 1.35rem 1.45rem;
        }

        .doc-inline-cta-button {
            justify-self: end;
            min-width: 9.6rem;
        }
    }

    @media (max-width: 767px) {
        .doc-hero {
            padding-top: 2.35rem;
            padding-bottom: 2rem;
        }

        .doc-title {
            font-size: clamp(2.15rem, 10vw, 3rem);
            max-width: 12.5ch;
        }

        .doc-description {
            font-size: 1rem;
            line-height: 1.62;
        }

        .doc-main :global(.prose) {
            max-width: 100%;
            line-height: 1.58;
        }

        .doc-inline-cta {
            margin-top: 2rem;
            padding: 1.05rem;
        }

        .doc-inline-cta-button {
            width: 100%;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .doc-inline-cta,
        .doc-inline-cta::before,
        .doc-inline-cta::after {
            transition: none;
        }

        .doc-inline-cta:hover,
        .doc-inline-cta:focus-within {
            transform: none;
        }
    }
</style>
