---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import "../styles/ui-utilities.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="404 - Halaman Tidak Ditemukan | Portal Online">
    <Navbar />
    <main class="error-page section pb-0">
        <div class="container text-center pb-8">
            <h1
                class="page-title font-display text-gradient mb-4"
                style="font-size: 6rem;"
            >
                404
            </h1>
            <h2 class="mb-4">Oops! Halaman Tidak Ditemukan</h2>
            <p class="page-subtitle mb-8">
                Maaf, halaman yang Anda cari tidak ada atau telah dipindahkan.
            </p>
            <a href="/" class="btn btn-primary"> Kembali ke Beranda </a>
        </div>
    </main>
    <Footer />
</Layout>

<style>
    .error-page {
        min-height: calc(100vh - 100px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding-top: 120px;
    }
</style>
