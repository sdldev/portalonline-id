---
import type { CollectionEntry } from "astro:content";
import { getCollection, selectFeaturedEntry } from "../../utils/collections";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import HoverLogoOverlay from "../../components/HoverLogoOverlay.astro";

export const prerender = true;

export const categories = ["article", "tips", "tutorial", "update"] as const;
type ContentCategory = (typeof categories)[number];
type ContentEntry = CollectionEntry<ContentCategory>;

export async function getStaticPaths() {
    const paths = await Promise.all(
        categories.map(async (cat) => {
            const items = await getCollection(cat);
            return {
                params: { category: cat },
                props: { items, categoryName: cat },
            };
        }),
    );

    return paths;
}

const { items, categoryName } = Astro.props as {
    items: ContentEntry[];
    categoryName: ContentCategory;
};

const sortedItems = [...items].sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const featuredItem = selectFeaturedEntry(sortedItems);
const restItems = featuredItem
    ? sortedItems.filter((item) => item.id !== featuredItem.id)
    : sortedItems;

const categoryMeta: Record<string, { title: string; subtitle: string; introText: string }> = {
    article: {
        title: "Artikel & Opini",
        subtitle: "Wawasan strategi, UX, performa, dan pengembangan portal digital.",
        introText:
            "Rangkaian tulisan ini merangkum pengalaman lapangan kami membangun website publikasi yang cepat, rapi, dan siap berkembang.",
    },
    tips: {
        title: "Tips Praktis",
        subtitle: "Panduan ringkas untuk meningkatkan kualitas website dan alur editorial.",
        introText:
            "Dari optimasi SEO sampai kebiasaan redaksi yang lebih efisien, kami rangkum poin-poin yang langsung bisa diterapkan.",
    },
    tutorial: {
        title: "Tutorial & Dokumentasi",
        subtitle: "Panduan teknis untuk memulai dan memaksimalkan penggunaan Portal Online.",
        introText:
            "Gunakan dokumentasi ini untuk memahami fondasi sistem, alur publish, dan praktik terbaik dalam pengelolaan konten.",
    },
    update: {
        title: "Update Produk",
        subtitle: "Informasi fitur baru, peningkatan sistem, dan pengumuman terbaru.",
        introText:
            "Ikuti perkembangan terbaru Portal Online agar tim Anda selalu bekerja dengan sistem yang lebih matang dan efisien.",
    },
};

const meta = categoryMeta[categoryName] || {
    title: categoryName.charAt(0).toUpperCase() + categoryName.slice(1),
    subtitle: `Kumpulan artikel kategori ${categoryName}`,
    introText: `Menampilkan semua arsip tulisan untuk kategori ${categoryName}.`,
};
---

<Layout title={`${meta.title} | Portal Online`} description={meta.subtitle}>
    <Navbar />

    <main class="page-content" id="main-content">
        <section class="category-hero section-frame">
            <div class="container category-hero-inner">
                <p class="eyebrow">Pustaka Editorial</p>
                <h1 class="category-title font-display">{meta.title}</h1>
                <p class="category-subtitle">{meta.subtitle}</p>
                <p class="category-intro">{meta.introText}</p>
            </div>
        </section>

        <section class="section category-listing">
            <div class="container category-listing-inner">
                <div class="list-topline">
                    <span class="list-count">{sortedItems.length} artikel tersedia</span>
                </div>

                {
                    sortedItems.length === 0 ? (
                        <p class="empty-state">Belum ada artikel di kategori ini.</p>
                    ) : (
                        <>
                            {
                                featuredItem && (
                                    <a href={`/${categoryName}/${featuredItem.id}`} class="featured-post hover-logo-overlay-target reveal">
                                        <HoverLogoOverlay preset="interactive" logoTop="calc(var(--hlo-logo-size) * -0.14)" logoSize="6rem" hoverOpacity={0.2} />
                                        <div class="hover-logo-overlay-content">
                                            <div class="featured-media">
                                                {
                                                    featuredItem.data.image ? (
                                                        <img src={featuredItem.data.image} alt={featuredItem.data.title} loading="lazy" />
                                                    ) : (
                                                        <div class="featured-placeholder" aria-hidden="true"></div>
                                                    )
                                                }
                                            </div>
                                            <div class="featured-content">
                                                <p class="featured-kicker">Sorotan</p>
                                                <h2 class="featured-title font-display">{featuredItem.data.title}</h2>
                                                {featuredItem.data.description && <p class="featured-desc">{featuredItem.data.description}</p>}
                                                <div class="featured-meta">
                                                    <time>
                                                        {new Date(featuredItem.data.date).toLocaleDateString("id-ID", {
                                                            year: "numeric",
                                                            month: "short",
                                                            day: "numeric",
                                                        })}
                                                    </time>
                                                    <span>·</span>
                                                    <span>{featuredItem.data.author}</span>
                                                </div>
                                            </div>
                                        </div>
                                    </a>
                                )
                            }

                            <ul class="article-list">
                                {restItems.map((item, index) => (
                                    <li class={`article-item reveal reveal-delay-${Math.min(index + 1, 4)}`}>
                                        <a href={`/${categoryName}/${item.id}`} class="article-link hover-logo-overlay-target">
                                            <HoverLogoOverlay preset="informational" logoTop="calc(var(--hlo-logo-size) * -0.14)" logoSize="4.9rem" hoverOpacity={0.16} />
                                            <div class="hover-logo-overlay-content">
                                                <div class="article-main">
                                                    <div class="article-meta">
                                                        <span class="article-cat">{item.data.category}</span>
                                                        <span>·</span>
                                                        <time>
                                                            {new Date(item.data.date).toLocaleDateString("id-ID", {
                                                                year: "numeric",
                                                                month: "short",
                                                                day: "numeric",
                                                            })}
                                                        </time>
                                                        <span>·</span>
                                                        <span>{item.data.author}</span>
                                                    </div>
                                                    <h3 class="article-title">{item.data.title}</h3>
                                                    {item.data.description && <p class="article-desc">{item.data.description}</p>}
                                                    {item.data.tags && item.data.tags.length > 0 && (
                                                        <div class="article-tags">
                                                            {item.data.tags.slice(0, 3).map((tag) => (
                                                                <span class="article-tag">#{tag}</span>
                                                            ))}
                                                        </div>
                                                    )}
                                                </div>
                                                {
                                                    item.data.image && (
                                                        <img src={item.data.image} alt={item.data.title} loading="lazy" class="article-thumb" />
                                                    )
                                                }
                                            </div>
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </>
                    )
                }
            </div>
        </section>
    </main>

    <Footer />
</Layout>

<style>
    .page-content {
        padding-top: 80px;
    }

    .category-hero {
        padding: 3.3rem 0 2.9rem;
    }

    .category-hero-inner {
        max-width: 68rem;
        display: grid;
        gap: 0.95rem;
    }

    .category-title {
        font-size: clamp(2.4rem, 6vw, 4.4rem);
        line-height: 1;
    }

    .category-subtitle {
        color: var(--color-text-muted);
        max-width: 62ch;
        line-height: 1.7;
    }

    .category-intro {
        color: var(--color-text-soft);
        max-width: 66ch;
        line-height: 1.75;
    }

    .category-listing-inner {
        display: grid;
        gap: 1.8rem;
    }

    .list-topline {
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        padding-bottom: 0.7rem;
    }

    .list-count {
        font-size: 0.8rem;
        color: var(--color-text-subtle);
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    .featured-post {
        border: 1px solid rgba(255, 255, 255, 0.11);
        border-radius: 1.1rem;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.012);
        display: grid;
        transition: border-color var(--transition-fast), transform var(--transition-fast);
    }

    .featured-post:hover {
        border-color: rgba(255, 255, 255, 0.22);
        transform: translateY(-2px);
    }

    .featured-post:focus-visible,
    .article-link:focus-visible {
        outline: 2px solid rgba(var(--color-primary), 0.85);
        outline-offset: 2px;
    }

    .featured-media {
        min-height: 260px;
        background: rgba(255, 255, 255, 0.014);
    }

    .featured-media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .featured-placeholder {
        min-height: 260px;
        background:
            linear-gradient(130deg, rgba(var(--color-primary), 0.16), transparent),
            rgba(255, 255, 255, 0.02);
    }

    .featured-content {
        padding: 1.35rem 1.3rem 1.45rem;
    }

    .featured-kicker {
        color: rgb(var(--color-primary));
        text-transform: uppercase;
        letter-spacing: 0.11em;
        font-size: 0.72rem;
        font-weight: 700;
    }

    .featured-title {
        margin-top: 0.55rem;
        font-size: clamp(1.8rem, 3vw, 2.7rem);
        line-height: 1.08;
    }

    .featured-desc {
        margin-top: 0.85rem;
        color: var(--color-text-muted);
        line-height: 1.72;
    }

    .featured-meta {
        margin-top: 0.9rem;
        color: var(--color-text-soft);
        font-size: 0.85rem;
        display: flex;
        gap: 0.4rem;
        align-items: center;
    }

    .article-list {
        list-style: none;
        display: grid;
        gap: 1.05rem;
    }

    .article-item {
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 0.95rem;
        background: rgba(255, 255, 255, 0.008);
    }

    .article-link {
        display: grid;
        gap: 1.15rem;
        padding: 1.2rem 1.1rem 1.25rem;
    }

    .article-meta {
        color: var(--color-text-soft);
        font-size: 0.8rem;
        display: flex;
        align-items: center;
        gap: 0.35rem;
        flex-wrap: wrap;
        text-transform: lowercase;
    }

    .article-cat {
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-weight: 700;
        color: rgb(var(--color-primary));
        font-size: 0.68rem;
    }

    .article-title {
        margin-top: 0.5rem;
        font-size: 1.42rem;
        line-height: 1.3;
        color: var(--color-text);
    }

    .article-desc {
        margin-top: 0.52rem;
        color: var(--color-text-muted);
        line-height: 1.68;
    }

    .article-tags {
        margin-top: 0.8rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    .article-tag {
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 999px;
        padding: 0.2rem 0.52rem;
        color: var(--color-text-soft);
        font-size: 0.74rem;
    }

    .article-thumb {
        width: 100%;
        border-radius: 0.7rem;
        border: 1px solid rgba(255, 255, 255, 0.14);
        object-fit: cover;
        max-height: 170px;
    }

    .empty-state {
        color: var(--color-text-muted);
    }

    @media (min-width: 980px) {
        .featured-post {
            grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
        }

        .featured-content {
            padding: 1.55rem 1.55rem 1.65rem;
        }

        .article-link {
            grid-template-columns: minmax(0, 1fr) 210px;
            align-items: center;
        }

        .article-thumb {
            max-height: 120px;
            height: 120px;
        }
    }

    @media (max-width: 767px) {
        .category-hero {
            padding-top: 2.8rem;
            padding-bottom: 2.45rem;
        }

        .featured-title {
            font-size: clamp(1.45rem, 8vw, 2rem);
        }

        .article-title {
            font-size: 1.2rem;
        }
    }
</style>
