---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import "../styles/ui-utilities.css";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Features from "../components/Features.astro";
// import DashboardPreview from "../components/DashboardPreview.astro";
import Comparison from "../components/Comparison.astro";
import Pricing from "../components/Pricing.astro";
import Testimonials from "../components/Testimonials.astro";
// import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
import Customers from "../components/Customers.astro";

const schema = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "WebSite",
            "@id": "https://portalonline.id/#website",
            url: "https://portalonline.id/",
            name: "Portal Online",
            description:
                "Platform CMS modern dengan dashboard canggih & tema eksklusif untuk portal berita, website sekolah, perusahaan & organisasi.",
            publisher: {
                "@id": "https://portalonline.id/#organization",
            },
        },
        {
            "@type": "Organization",
            "@id": "https://portalonline.id/#organization",
            name: "Portal Online",
            url: "https://portalonline.id/",
            logo: {
                "@type": "ImageObject",
                url: "https://portalonline.id/portalonline-logo.avif",
            },
        },
    ],
};
---

<Layout
    title="Portal Online | Custom CMS"
    description="Portal Online adalah platform custom CMS Khusus untuk portal Berita, Sekolah, Perusahaan, dan Organisasi dengan dashboard canggih dan tema eksklusif."
    schema={schema}
>
    <Navbar />
    <main id="main-content">
        <Hero />
        <Customers />
        <Features />
        <!-- <DashboardPreview /> -->
        <Comparison />
        <Pricing />
        <Testimonials />
        <!-- <FAQ /> -->
        <CTA />
    </main>
    <Footer />
</Layout>
