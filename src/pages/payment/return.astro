---
import Layout from "../../layouts/Layout.astro";
import "../../styles/ui-utilities.css";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";

export const prerender = false;
---

<Layout
    title="Pembayaran Sedang Diproses | Portal Online"
    description="Pembayaran Portal Online sedang diproses. Tim kami akan menghubungi Anda setelah status pembayaran terverifikasi."
>
    <Navbar />
    <main id="main-content">
        <section class="section payment-focus-section" aria-labelledby="payment-return-title">
            <div class="container payment-focus-shell">
                <div class="payment-focus-card">
                    <span class="payment-focus-badge">Pembayaran Duitku</span>
                    <h1 class="payment-focus-title font-display" id="payment-return-title">
                        Pembayaran sedang diproses
                    </h1>
                    <p>
                        Kami akan menghubungi Anda setelah status pembayaran terverifikasi.
                    </p>
                    <p class="payment-focus-note">
                        Halaman ini bukan konfirmasi final pembayaran.
                    </p>
                    <div class="payment-focus-actions">
                        <a class="btn btn-primary" href="/">Kembali ke Beranda</a>
                        <a
                            class="btn btn-secondary"
                            href="https://wa.me/6285783024799?text=Halo,%20saya%20ingin%20menanyakan%20status%20pembayaran%20Portal%20Online."
                            target="_blank"
                            rel="nofollow noopener noreferrer"
                        >Hubungi WhatsApp</a>
                    </div>
                </div>
            </div>
        </section>
    </main>
    <Footer />
</Layout>

<style>
    .payment-focus-section {
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .payment-focus-shell {
        max-width: 720px;
    }

    .payment-focus-card {
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 1.15rem;
        background: rgba(255, 255, 255, 0.025);
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.18);
        padding: clamp(1.2rem, 4vw, 2rem);
    }

    .payment-focus-badge {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        border-radius: 999px;
        border: 1px solid rgba(var(--color-primary), 0.24);
        background: rgba(var(--color-primary), 0.08);
        color: rgb(var(--color-primary));
        padding: 0.34rem 0.68rem;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        line-height: 1;
        text-transform: uppercase;
    }

    .payment-focus-title {
        margin-top: 1rem;
        font-size: clamp(2.15rem, 5vw, 3.7rem);
        line-height: 1.04;
    }

    .payment-focus-card p {
        margin-top: 0.9rem;
        color: var(--color-text-soft);
        line-height: 1.7;
    }

    .payment-focus-note {
        font-size: 0.92rem;
    }

    .payment-focus-actions {
        margin-top: 1.35rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .payment-focus-actions .btn-primary {
        background: rgb(var(--color-primary));
        color: #18120a;
        border-color: rgba(var(--color-primary), 0.85);
        box-shadow: 0 14px 32px rgba(var(--color-primary), 0.18);
    }

    .payment-focus-actions .btn-primary:hover {
        box-shadow: 0 18px 38px rgba(var(--color-primary), 0.22);
    }
</style>
