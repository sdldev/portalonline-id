---
import { env } from "cloudflare:workers";

import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { getDuitkuConfig } from "../../lib/duitku";

export const prerender = false;

const reference = Astro.url.searchParams.get("reference") ?? "";
const paymentUrl = Astro.url.searchParams.get("paymentUrl") ?? "";
const duitku = getDuitkuConfig(env);
---

<Layout
    title="Lanjutkan Pembayaran | Portal Online"
    description="Lanjutkan pembayaran Portal Online melalui Duitku Sandbox."
>
    <Navbar />
    <main id="main-content">
        <section class="section payment-focus-section" aria-labelledby="payment-start-title">
            <div class="container payment-focus-shell">
                <div class="payment-focus-card">
                    <span class="payment-focus-badge">Duitku Sandbox</span>
                    <h1 class="payment-focus-title font-display" id="payment-start-title">
                        Lanjutkan pembayaran
                    </h1>
                    <p>
                        Kami sedang membuka halaman pembayaran. Jika tidak otomatis, tekan tombol di bawah.
                    </p>
                    <div class="payment-focus-actions">
                        {
                            reference ? (
                                <button class="btn btn-primary" type="button" id="duitku-pay-button" data-reference={reference}>
                                    Lanjutkan ke Pembayaran
                                </button>
                            ) : paymentUrl ? (
                                <a class="btn btn-primary" href={paymentUrl}>Lanjutkan ke Pembayaran</a>
                            ) : (
                                <a class="btn btn-secondary" href="/#pricing">Kembali ke Paket</a>
                            )
                        }
                    </div>
                </div>
            </div>
        </section>
    </main>
    <Footer />
</Layout>

<style>
    .payment-focus-section {
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .payment-focus-shell {
        max-width: 720px;
    }

    .payment-focus-card {
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 1.15rem;
        background: rgba(255, 255, 255, 0.025);
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.18);
        padding: clamp(1.2rem, 4vw, 2rem);
    }

    .payment-focus-badge {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        border-radius: 999px;
        border: 1px solid rgba(var(--color-primary), 0.24);
        background: rgba(var(--color-primary), 0.08);
        color: rgb(var(--color-primary));
        padding: 0.34rem 0.68rem;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        line-height: 1;
        text-transform: uppercase;
    }

    .payment-focus-title {
        margin-top: 1rem;
        font-size: clamp(2.15rem, 5vw, 3.7rem);
        line-height: 1.04;
    }

    .payment-focus-card p {
        margin-top: 0.9rem;
        color: var(--color-text-soft);
        line-height: 1.7;
    }

    .payment-focus-actions {
        margin-top: 1.35rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }
</style>

{reference && <script src={duitku.popScriptUrl}></script>}

<script define:vars={{ hasReference: Boolean(reference) }}>
    if (hasReference) {
        const button = document.getElementById("duitku-pay-button");
        const reference = button?.getAttribute("data-reference");

        function processPayment() {
            if (!reference || typeof checkout === "undefined") return;

            checkout.process(reference, {
                successEvent: function () {
                    window.location.href = "/payment/return";
                },
                pendingEvent: function () {
                    window.location.href = "/payment/return";
                },
                errorEvent: function () {
                    window.location.href = "/checkout/starter?error=payment_failed";
                },
                closeEvent: function () {
                    // Keep the buyer on this page so they can retry with the button.
                },
            });
        }

        button?.addEventListener("click", processPayment);
        window.addEventListener("load", processPayment);
    }
</script>
