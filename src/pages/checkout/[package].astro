---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import CheckoutBuyerForm from "../../components/checkout/CheckoutBuyerForm.astro";
import CheckoutSummary from "../../components/checkout/CheckoutSummary.astro";
import { billingPeriods, getPackagePrice, getServicePackage, normalizeBillingPeriod } from "../../data/servicePackages";

export const prerender = false;

const packageId = Astro.params.package;
const servicePackage = getServicePackage(packageId);

if (!servicePackage || !servicePackage.checkoutEnabled) {
    return Astro.redirect("/#pricing", 302);
}

const period = normalizeBillingPeriod(Astro.url.searchParams.get("period"));
const price = getPackagePrice(servicePackage, period);
const hasPaymentError = Astro.url.searchParams.get("error") === "payment_failed";
const hasValidationError = Astro.url.searchParams.get("error") === "invalid_form";

if (price === null) {
    return Astro.redirect("/#pricing", 302);
}
---

<Layout
    title={`Checkout Paket ${servicePackage.name} | Portal Online`}
    description={`Isi data kontak untuk melanjutkan pembayaran paket ${servicePackage.name} ${billingPeriods[period].label} Portal Online melalui Duitku Sandbox.`}
>
    <Navbar />
    <main id="main-content">
        <section class="section checkout-section" aria-labelledby="checkout-page-title">
            <div class="container checkout-shell">
                <div class="checkout-topbar">
                    <a class="checkout-back" href="/#pricing">← Ganti paket</a>
                    <span class="checkout-env-badge">Duitku Sandbox</span>
                </div>

                <header class="checkout-page-header">
                    <p class="eyebrow">Checkout</p>
                    <h1 class="checkout-page-title font-display" id="checkout-page-title">
                        Checkout Paket {servicePackage.name}
                    </h1>
                    <p>Isi data kontak, lalu lanjutkan pembayaran aman via Duitku.</p>
                </header>

                <div class="checkout-grid">
                    <CheckoutBuyerForm
                        servicePackage={servicePackage}
                        period={period}
                        hasPaymentError={hasPaymentError}
                        hasValidationError={hasValidationError}
                    />

                    <div class="checkout-side">
                        <CheckoutSummary servicePackage={servicePackage} period={period} price={price} />
                    </div>
                </div>
            </div>
        </section>
    </main>
    <Footer />
</Layout>

<style is:global>
    .checkout-section {
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .checkout-shell,
    .checkout-page-header,
    .checkout-side,
    .checkout-form,
    .checkout-form-header,
    .checkout-field-grid,
    .checkout-optional-fields,
    .checkout-payment-note {
        display: grid;
    }

    .checkout-shell {
        max-width: 1120px;
        gap: 1.15rem;
    }

    .checkout-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .checkout-back,
    .checkout-help a,
    .checkout-summary-link {
        color: rgb(var(--color-primary));
        font-weight: 700;
    }

    .checkout-back {
        color: var(--color-text-soft);
        text-decoration: none;
        width: fit-content;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.92rem;
        transition: color var(--transition-fast), transform var(--transition-fast);
    }

    .checkout-back:hover {
        color: rgb(var(--color-primary));
        transform: translateX(-2px);
    }

    .checkout-env-badge,
    .checkout-status-badge {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        border-radius: 999px;
        border: 1px solid rgba(var(--color-primary), 0.24);
        background: rgba(var(--color-primary), 0.08);
        color: rgb(var(--color-primary));
        padding: 0.34rem 0.68rem;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        line-height: 1;
        text-transform: uppercase;
    }

    .checkout-page-header {
        max-width: 680px;
        gap: 0.55rem;
        padding: 0.35rem 0 0.55rem;
    }

    .checkout-page-title {
        margin: 0;
        font-size: clamp(2.25rem, 5vw, 4rem);
        line-height: 1.02;
    }

    .checkout-page-header p:not(.eyebrow),
    .checkout-description,
    .checkout-summary-meta,
    .checkout-price-period,
    .checkout-price-note,
    .checkout-form-header p,
    .checkout-field > small,
    .checkout-optional-title span,
    .checkout-payment-note,
    .checkout-help {
        color: var(--color-text-soft);
    }

    .checkout-page-header p:not(.eyebrow),
    .checkout-description,
    .checkout-form-header p,
    .checkout-payment-note,
    .checkout-help {
        line-height: 1.65;
    }

    .checkout-grid {
        display: grid;
        gap: 1rem;
    }

    .checkout-summary,
    .checkout-form {
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 1.15rem;
        background: rgba(255, 255, 255, 0.025);
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.18);
        padding: clamp(1.1rem, 3vw, 1.55rem);
    }

    .checkout-side {
        gap: 1rem;
        order: -1;
    }

    .checkout-summary {
        overflow: hidden;
    }

    .checkout-summary-topline {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.8rem;
    }

    .checkout-title {
        margin-top: 0.9rem;
        font-size: clamp(1.55rem, 3vw, 2.1rem);
        line-height: 1.1;
    }

    .checkout-description {
        margin-top: 0.55rem;
        font-size: 0.95rem;
    }

    .checkout-price-card {
        margin-top: 1rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        padding: 1rem 0;
    }

    .checkout-price-label,
    .checkout-price-note {
        color: var(--color-text-soft);
        font-size: 0.82rem;
    }

    .checkout-price {
        margin-top: 0.4rem;
        display: flex;
        align-items: baseline;
        gap: 0.45rem;
        flex-wrap: wrap;
    }

    .checkout-price-value {
        font-size: clamp(1.9rem, 4vw, 2.55rem);
        line-height: 1;
    }

    .checkout-price-note {
        display: block;
        margin-top: 0.45rem;
    }

    .checkout-benefit {
        margin-top: 0.85rem;
        border-radius: 0.8rem;
        background: rgba(var(--color-primary), 0.08);
        color: rgb(var(--color-primary));
        padding: 0.72rem 0.85rem;
        font-weight: 700;
        line-height: 1.5;
    }

    .checkout-includes {
        margin-top: 1rem;
    }

    .checkout-card-heading {
        margin: 0;
        font-size: 1rem;
        line-height: 1.25;
    }

    .checkout-features {
        margin-top: 0.75rem;
        list-style: none;
        display: grid;
        gap: 0.55rem;
    }

    .checkout-features li {
        color: var(--color-text-soft);
        font-size: 0.9rem;
        line-height: 1.55;
        padding-left: 1.25rem;
        position: relative;
    }

    .checkout-features li::before {
        content: "✓";
        color: rgb(var(--color-primary));
        font-weight: 900;
        position: absolute;
        left: 0;
        top: 0;
    }

    .checkout-summary-link {
        margin-top: 1rem;
        display: inline-flex;
        width: fit-content;
        text-decoration: none;
        font-size: 0.9rem;
    }

    .checkout-form {
        gap: 1rem;
    }

    .checkout-form-header {
        gap: 0.45rem;
    }

    .checkout-form h2 {
        font-size: clamp(1.55rem, 3vw, 2rem);
        margin: 0;
    }

    .checkout-field-grid,
    .checkout-optional-fields {
        gap: 0.85rem;
    }

    .checkout-optional-fields {
        margin-top: 0.15rem;
        padding-top: 1rem;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .checkout-optional-title {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 0.75rem;
        color: var(--color-text);
        font-weight: 800;
    }

    .checkout-optional-title span {
        font-size: 0.82rem;
        font-weight: 600;
    }

    .checkout-field {
        display: grid;
        gap: 0.42rem;
        color: var(--color-text);
        font-weight: 700;
    }

    .checkout-field span {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        font-size: 0.94rem;
    }

    .checkout-field strong,
    .checkout-field small {
        color: var(--color-text-soft);
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .checkout-field strong {
        color: rgb(var(--color-primary));
    }

    .checkout-field > small {
        font-size: 0.82rem;
        font-weight: 500;
        letter-spacing: 0;
        text-transform: none;
    }

    .checkout-form input,
    .checkout-form textarea {
        width: 100%;
        border: 1px solid rgba(255, 255, 255, 0.13);
        border-radius: 0.78rem;
        background: rgba(10, 11, 13, 0.48);
        color: var(--color-text);
        padding: 0.88rem 0.95rem;
        font: inherit;
        transition: border-color var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast);
    }

    .checkout-form input::placeholder,
    .checkout-form textarea::placeholder {
        color: rgba(167, 159, 145, 0.68);
    }

    .checkout-form input:focus,
    .checkout-form textarea:focus {
        outline: none;
        border-color: rgba(var(--color-primary), 0.72);
        background: rgba(10, 11, 13, 0.7);
        box-shadow: 0 0 0 3px rgba(var(--color-primary), 0.14);
    }

    .checkout-alert,
    .checkout-payment-note {
        border-radius: 0.8rem;
        padding: 0.8rem 0.9rem;
        line-height: 1.55;
    }

    .checkout-alert {
        border: 1px solid rgba(255, 190, 90, 0.32);
        color: #ffd89a;
        background: rgba(255, 190, 90, 0.08);
    }

    .checkout-payment-note {
        gap: 0.18rem;
        border: 1px solid rgba(255, 255, 255, 0.09);
        background: rgba(255, 255, 255, 0.03);
        font-size: 0.88rem;
    }

    .checkout-payment-note strong {
        color: var(--color-text);
    }

    .checkout-submit {
        width: 100%;
        min-height: 3.1rem;
        justify-content: center;
    }

    .checkout-submit svg {
        transition: transform var(--transition-fast);
    }

    .checkout-submit:hover svg {
        transform: translateX(3px);
    }

    .checkout-help {
        font-size: 0.9rem;
        text-align: center;
    }

    @media (min-width: 720px) {
        .checkout-field-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .checkout-field-wide {
            grid-column: 1 / -1;
        }
    }

    @media (min-width: 980px) {
        .checkout-grid {
            grid-template-columns: minmax(0, 1.25fr) minmax(18rem, 0.75fr);
            align-items: start;
        }

        .checkout-side {
            position: sticky;
            top: 6rem;
            order: 0;
        }
    }
</style>

<script>
    (function () {
        function initCheckoutFormRedirect() {
            const form = document.querySelector("[data-checkout-form]");
            if (!(form instanceof HTMLFormElement) || form.dataset.enhanced === "true") return;

            form.dataset.enhanced = "true";
            form.addEventListener("submit", async (event) => {
                if (!form.checkValidity()) return;

                event.preventDefault();

                const submitButton = form.querySelector('button[type="submit"]');
                if (submitButton instanceof HTMLButtonElement) {
                    submitButton.disabled = true;
                    submitButton.setAttribute("aria-busy", "true");
                    submitButton.innerHTML = "<span>Memproses…</span>";
                }

                try {
                    const response = await fetch(form.action, {
                        method: "POST",
                        body: new FormData(form),
                        credentials: "same-origin",
                        redirect: "manual",
                        headers: {
                            Accept: "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
                        },
                    });

                    const result = await response.json();
                    if (response.ok && typeof result.redirectUrl === "string") {
                        window.location.href = result.redirectUrl;
                        return;
                    }

                    throw new Error("Missing checkout redirect");
                } catch {
                    const packageId = form.querySelector('input[name="packageId"]');
                    const period = form.querySelector('input[name="period"]');
                    const safePackageId = packageId instanceof HTMLInputElement ? packageId.value : "starter";
                    const safePeriod = period instanceof HTMLInputElement ? period.value : "monthly";
                    window.location.href = `/checkout/${safePackageId}?period=${safePeriod}&error=payment_failed`;
                }
            });
        }

        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", initCheckoutFormRedirect);
        } else {
            initCheckoutFormRedirect();
        }

        document.addEventListener("astro:page-load", initCheckoutFormRedirect);
    })();
</script>
