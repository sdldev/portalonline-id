---
import { Image } from "astro:assets";
import navLogo from "../../public/portalonline-40x40.webp";

const navLinks = [
    { name: "Beranda", href: "/" },
    {
        name: "Artikel",
        href: "#",
        dropdown: [
            { name: "Tips", href: "/tips/" },
            { name: "Artikel", href: "/article/" },
        ],
    },
    { name: "Tentang", href: "/about/" },
    { name: "Kontak", href: "/contact/" },
];
---

<nav class="navbar" id="navbar">
    <div class="container navbar-shell">
        <a href="/" class="navbar-logo">
            <Image
                src={navLogo}
                alt="Logo Portal Online"
                width={40}
                height={40}
                class="logo-icon"
                fetchpriority="high"
                loading="eager"
                format="webp"
            />
            <span class="logo-text">Portal Online</span>
        </a>

        <div class="navbar-links hide-mobile" aria-label="Navigasi utama">
            {
                navLinks.map((link) =>
                    link.dropdown ? (
                        <div class="nav-item-dropdown" data-dropdown-root>
                            <button
                                class="nav-link dropdown-trigger"
                                id="desktop-article-trigger"
                                aria-haspopup="menu"
                                aria-controls="desktop-article-menu"
                                aria-expanded="false"
                                type="button"
                            >
                                {link.name}
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="14"
                                    height="14"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="chevron-down"
                                >
                                    <path d="m6 9 6 6 6-6" />
                                </svg>
                            </button>
                            <div class="dropdown-menu" id="desktop-article-menu" role="menu">
                                {link.dropdown.map((subItem) => (
                                    <a href={subItem.href} class="dropdown-item" role="menuitem" tabindex="-1"
                                        >{subItem.name}</a
                                    >
                                ))}
                            </div>
                        </div>
                    ) : (
                        <a href={link.href} class="nav-link">{link.name}</a>
                    ),
                )
            }
        </div>

        <div class="navbar-actions">
            <button
                class="mobile-menu-btn hide-desktop"
                id="mobile-menu-btn"
                aria-label="Toggle menu"
                aria-controls="mobile-menu"
                aria-expanded="false"
                type="button"
            >
                <svg
                    class="menu-icon"
                    xmlns="http://www.w3.org/2000/svg"
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <line x1="4" x2="20" y1="12" y2="12"></line>
                    <line x1="4" x2="20" y1="6" y2="6"></line>
                    <line x1="4" x2="20" y1="18" y2="18"></line>
                </svg>
                <svg
                    class="close-icon"
                    xmlns="http://www.w3.org/2000/svg"
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <path d="M18 6 6 18"></path>
                    <path d="m6 6 12 12"></path>
                </svg>
            </button>
        </div>
    </div>

    <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
        <div class="mobile-menu-inner">
            {
                navLinks.map((link) =>
                    link.dropdown ? (
                        <details class="mobile-dropdown">
                            <summary class="mobile-nav-link">{link.name}</summary>
                            <div class="mobile-dropdown-menu">
                                {link.dropdown.map((subItem) => (
                                    <a href={subItem.href} class="mobile-nav-link sub-link">{subItem.name}</a>
                                ))}
                            </div>
                        </details>
                    ) : (
                        <a href={link.href} class="mobile-nav-link">{link.name}</a>
                    ),
                )
            }
        </div>
    </div>
</nav>

<style>
    .navbar {
        position: fixed;
        inset: 0 0 auto;
        z-index: 100;
        height: 80px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(10, 11, 14, 0.64);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        transition: background-color var(--transition-base), border-color var(--transition-base);
    }

    .navbar.scrolled {
        background: rgba(10, 11, 14, 0.82);
        border-bottom-color: rgba(255, 255, 255, 0.14);
    }

    .navbar-shell {
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.25rem;
    }

    .navbar-logo {
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        transition: opacity var(--transition-fast);
    }

    .navbar-logo:hover {
        opacity: 0.92;
    }

    .logo-icon {
        border-radius: 0.6rem;
    }

    .logo-text {
        font-family: var(--font-primary);
        font-size: 1.55rem;
        line-height: 1;
        font-weight: 700;
        letter-spacing: -0.01em;
    }

    .navbar-links {
        display: flex;
        align-items: center;
        gap: 0.35rem;
    }

    .nav-link {
        color: var(--color-text-muted);
        padding: 0.5rem 0.85rem;
        border-radius: 999px;
        font-size: 0.875rem;
        font-weight: 600;
        transition: color var(--transition-fast), background-color var(--transition-fast);
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
    }

    .nav-link:hover {
        color: var(--color-text);
        background: rgba(255, 255, 255, 0.06);
    }

    .nav-link:focus-visible,
    .dropdown-item:focus-visible,
    .mobile-menu-btn:focus-visible,
    .mobile-nav-link:focus-visible {
        outline: 2px solid rgba(var(--color-primary), 0.85);
        outline-offset: 2px;
    }

    .nav-item-dropdown {
        position: relative;
    }

    .nav-item-dropdown::after {
        content: "";
        position: absolute;
        top: 100%;
        left: 0;
        width: 100%;
        height: 0.75rem;
    }

    .dropdown-trigger {
        border: none;
        background: transparent;
        cursor: pointer;
        font-family: inherit;
    }

    .chevron-down {
        transition: transform var(--transition-fast);
    }

    .nav-item-dropdown:hover .chevron-down {
        transform: rotate(180deg);
    }

    .nav-item-dropdown.is-open .chevron-down {
        transform: rotate(180deg);
    }

    .dropdown-menu {
        position: absolute;
        top: calc(100% + 0.6rem);
        left: 50%;
        transform: translateX(-50%);
        min-width: 180px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 0.9rem;
        background: rgba(15, 16, 19, 0.96);
        padding: 0.35rem;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transition: opacity 0.2s ease, visibility 0.2s ease;
    }

    .nav-item-dropdown:hover .dropdown-menu {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
    }

    .nav-item-dropdown.is-open .dropdown-menu {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
    }

    .dropdown-item {
        display: block;
        padding: 0.6rem 0.75rem;
        border-radius: 0.7rem;
        color: var(--color-text-muted);
        font-size: 0.85rem;
    }

    .dropdown-item:hover {
        color: var(--color-text);
        background: rgba(255, 255, 255, 0.06);
    }

    .navbar-actions {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .mobile-menu-btn {
        width: 2.5rem;
        height: 2.5rem;
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 0.7rem;
        color: var(--color-text);
        background: rgba(255, 255, 255, 0.02);
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .close-icon {
        display: none;
    }

    .mobile-menu {
        position: fixed;
        inset: 80px 0 auto;
        background: rgba(10, 11, 14, 0.95);
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        opacity: 0;
        visibility: hidden;
        transform: translateY(-6px);
        transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    }

    .mobile-menu.open {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }

    .mobile-menu-inner {
        padding: 0.9rem 1.25rem 1.2rem;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .mobile-nav-link {
        width: 100%;
        display: block;
        padding: 0.85rem 0.4rem;
        color: var(--color-text-muted);
        font-weight: 600;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .mobile-nav-link:hover {
        color: var(--color-text);
    }

    .mobile-dropdown {
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .mobile-dropdown > summary {
        list-style: none;
        cursor: pointer;
    }

    .mobile-dropdown > summary::-webkit-details-marker {
        display: none;
    }

    .mobile-dropdown-menu {
        padding: 0 0 0.5rem 0.85rem;
        display: grid;
        gap: 0.3rem;
    }

    .mobile-nav-link.sub-link {
        border-bottom: none;
        padding: 0.6rem 0.4rem;
        font-size: 0.9rem;
    }

    .mobile-cta {
        width: 100%;
        margin-top: 0.8rem;
    }

    @media (max-width: 767px) {
        .logo-text {
            font-size: 1.34rem;
        }

        .logo-icon {
            width: 36px;
            height: 36px;
        }
    }
</style>

<script>
    function initNavbar() {
        const navbar = document.getElementById("navbar");
        const mobileMenuBtn = document.getElementById("mobile-menu-btn");
        const mobileMenu = document.getElementById("mobile-menu");
        const menuIcon = mobileMenuBtn?.querySelector(".menu-icon");
        const closeIcon = mobileMenuBtn?.querySelector(".close-icon");
        const dropdownRoot = navbar?.querySelector<HTMLElement>("[data-dropdown-root]");
        const dropdownTrigger = dropdownRoot?.querySelector<HTMLButtonElement>(
            ".dropdown-trigger",
        );
        const dropdownMenu = dropdownRoot?.querySelector<HTMLElement>(".dropdown-menu");
        const dropdownItems = Array.from(
            dropdownMenu?.querySelectorAll<HTMLElement>(".dropdown-item") ?? [],
        );
        let dropdownCloseTimer: number | null = null;

        const cleanups: Array<() => void> = [];
        const addListener = (
            target: EventTarget | null | undefined,
            event: string,
            handler: (event: Event) => void,
            options?: boolean | AddEventListenerOptions,
        ) => {
            if (!target) return;
            target.addEventListener(event, handler, options);
            cleanups.push(() => target.removeEventListener(event, handler, options));
        };

        const win = window as Window & {
            __portalNavbarCleanup?: () => void;
        };
        if (typeof win.__portalNavbarCleanup === "function") {
            win.__portalNavbarCleanup();
        }

        const handleScroll = () => {
            if (window.scrollY > 12) {
                navbar?.classList.add("scrolled");
                return;
            }
            navbar?.classList.remove("scrolled");
        };

        addListener(window, "scroll", handleScroll, { passive: true });
        handleScroll();

        const focusDropdownItem = (index: number) => {
            if (dropdownItems.length === 0) return;
            const boundedIndex = (index + dropdownItems.length) % dropdownItems.length;
            dropdownItems[boundedIndex]?.focus();
        };

        const setDropdownOpen = (open: boolean) => {
            dropdownRoot?.classList.toggle("is-open", open);
            dropdownTrigger?.setAttribute("aria-expanded", String(open));
        };

        const cancelDropdownClose = () => {
            if (!dropdownCloseTimer) return;
            clearTimeout(dropdownCloseTimer);
            dropdownCloseTimer = null;
        };

        const scheduleDropdownClose = (delay = 120) => {
            cancelDropdownClose();
            dropdownCloseTimer = window.setTimeout(() => {
                closeDropdown();
                dropdownCloseTimer = null;
            }, delay);
        };

        const closeDropdown = ({ returnFocus = false }: { returnFocus?: boolean } = {}) => {
            cancelDropdownClose();
            const isOpen = dropdownRoot?.classList.contains("is-open") ?? false;
            if (!isOpen) return;
            setDropdownOpen(false);
            if (returnFocus) dropdownTrigger?.focus();
        };

        const setMobileMenuOpen = (open: boolean) => {
            mobileMenu?.classList.toggle("open", open);
            mobileMenuBtn?.setAttribute("aria-expanded", String(open));
            mobileMenu?.setAttribute("aria-hidden", String(!open));
            mobileMenuBtn?.setAttribute("aria-label", open ? "Tutup menu" : "Buka menu");
            if (menuIcon && closeIcon) {
                menuIcon.setAttribute("style", open ? "display:none" : "display:block");
                closeIcon.setAttribute("style", open ? "display:block" : "display:none");
            }
        };

        addListener(mobileMenuBtn, "click", () => {
            const isOpen = mobileMenu?.classList.contains("open") ?? false;
            setMobileMenuOpen(!isOpen);
        });

        mobileMenu?.querySelectorAll("a").forEach((link) => {
            addListener(link, "click", () => {
                setMobileMenuOpen(false);
            });
        });

        addListener(dropdownTrigger, "click", () => {
            const isOpen = dropdownRoot?.classList.contains("is-open") ?? false;
            setDropdownOpen(!isOpen);
        });

        addListener(dropdownRoot, "mouseenter", () => {
            cancelDropdownClose();
            setDropdownOpen(true);
        });

        addListener(dropdownRoot, "mouseleave", () => {
            scheduleDropdownClose();
        });

        addListener(dropdownRoot, "focusin", () => {
            cancelDropdownClose();
            setDropdownOpen(true);
        });

        addListener(dropdownRoot, "focusout", (event) => {
            const focusEvent = event as FocusEvent;
            const nextTarget = focusEvent.relatedTarget;
            if (nextTarget instanceof Node && dropdownRoot?.contains(nextTarget)) return;
            scheduleDropdownClose(0);
        });

        addListener(dropdownTrigger, "keydown", (event) => {
            const keyboardEvent = event as KeyboardEvent;
            const key = keyboardEvent.key;
            if (key === "Enter" || key === " " || key === "ArrowDown") {
                keyboardEvent.preventDefault();
                setDropdownOpen(true);
                focusDropdownItem(0);
                return;
            }
            if (key === "ArrowUp") {
                keyboardEvent.preventDefault();
                setDropdownOpen(true);
                focusDropdownItem(dropdownItems.length - 1);
                return;
            }
            if (key === "Escape") {
                keyboardEvent.preventDefault();
                closeDropdown({ returnFocus: true });
            }
        });

        addListener(dropdownMenu, "keydown", (event) => {
            const keyboardEvent = event as KeyboardEvent;
            const key = keyboardEvent.key;
            const activeElement = document.activeElement;
            const activeIndex =
                activeElement instanceof HTMLElement
                    ? dropdownItems.indexOf(activeElement)
                    : -1;

            if (key === "Escape") {
                keyboardEvent.preventDefault();
                closeDropdown({ returnFocus: true });
                return;
            }

            if (key === "ArrowDown") {
                keyboardEvent.preventDefault();
                focusDropdownItem(activeIndex + 1);
                return;
            }

            if (key === "ArrowUp") {
                keyboardEvent.preventDefault();
                focusDropdownItem(activeIndex - 1);
                return;
            }

            if (key === "Tab") {
                closeDropdown();
            }
        });

        addListener(document, "pointerdown", (event) => {
            const target = event.target;
            if (!(target instanceof Node)) return;

            if (dropdownRoot && !dropdownRoot.contains(target)) {
                closeDropdown();
            }

            const menuOpen = mobileMenu?.classList.contains("open") ?? false;
            if (!menuOpen) return;
            if (mobileMenu?.contains(target) || mobileMenuBtn?.contains(target)) return;
            setMobileMenuOpen(false);
        });

        addListener(document, "focusin", (event) => {
            const target = event.target;
            if (!(target instanceof Node)) return;
            if (dropdownRoot?.contains(target)) return;
            closeDropdown();
        });

        addListener(document, "keydown", (event) => {
            const keyboardEvent = event as KeyboardEvent;
            if (keyboardEvent.key !== "Escape") return;
            closeDropdown({ returnFocus: true });
            const menuOpen = mobileMenu?.classList.contains("open") ?? false;
            if (!menuOpen) return;
            setMobileMenuOpen(false);
            mobileMenuBtn?.focus();
        });

        setDropdownOpen(false);
        setMobileMenuOpen(false);

        win.__portalNavbarCleanup = () => {
            cancelDropdownClose();
            cleanups.forEach((cleanup) => cleanup());
        };
    }

    initNavbar();
    document.addEventListener("astro:page-load", initNavbar);
</script>
