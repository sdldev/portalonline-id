---
import HoverLogoOverlay from "./HoverLogoOverlay.astro";

const plans = [
    {
        id: "starter",
        name: "Starter",
        priceIdr: "150K",
        period: "/bulan",
        description: "Cocok untuk media baru/media daerah .",
        features: [
            "Penerbitan artikel tidak terbatas",
            "Optimasi SEO",
            "Manajemen user hingga 3 akun",
            "1 Theme premium",
            "Free Domain .id, com jika berlangganan 1 tahun",
        ],
        cta: "Mulai Starter",
        popular: false,
    },
    {
        id: "pro",
        name: "Pro",
        priceIdr: "300K",
        period: "/bulan",
        description: "Dirancang untuk media yang sudah berjalan dengan trafik tinggi.",
        features: [
            "Penerbitan artikel tidak terbatas",
            "Optimasi SEO dan analitik",
            "Manajemen user hingga 10 akun",
            "Free akses ke semua theme premium",
            "Free Domain .id, com jika berlangganan 1 tahun",
            "Prioritas dukungan teknis",
            "Komunikasi langsung dengan tim developer untuk penyesuaian fitur dan troubleshooting",
        ],
        cta: "Mulai Pro",
        popular: true,
    },
    {
        id: "enterprise",
        name: "Enterprise",
        priceIdr: "Custom",
        period: "",
        description: "Untuk kebutuhan migrasi besar, integrasi sistem, dan infrastruktur khusus.",
        features: [
            "SLA uptime 99.9%",
            "Integrasi API eksternal",
            "Migrasi data CMS lama",
            "Account manager khusus",
        ],
        cta: "Diskusikan Kebutuhan",
        popular: false,
    },
];

const faqs = [
    {
        q: "Aplikasi bisa langsung digunakan?",
        a: "Ya. CMS Portal Online sudah siap digunakan. Setelah anda akun anda aktif, dan domain sudah di arahkan ke server kami, anda bisa langsung login dan mulai membuat konten. Kami juga menyediakan dokumentasi lengkap dan tutorial untuk membantu anda memulai dengan cepat.",
    },
    {
        q: "Apakah fitur SEO sudah termasuk?",
        a: "Ya, semua paket sudah termasuk fitur optimasi SEO dasar seperti meta tag otomatis, sitemap, dan struktur URL yang ramah SEO. Paket Pro juga dilengkapi dengan analitik SEO untuk membantu anda memantau performa konten dan mendapatkan rekomendasi optimasi lebih lanjut.",        
    },
    {
        q: "Apakah ada biaya tambahan?",
        a: "Tidak ada biaya tersembunyi. Semua layanan dan fitur yang termasuk dalam paket sudah dijelaskan secara transparan di awal. Biaya tambahan hanya berlaku untuk kebutuhan khusus di luar cakupan paket, yang akan didiskusikan terlebih dahulu.",
    },
    {
        q: "Apakah bisa migrasi dari WordPress?",
        a: "Migrasi dari WordPress hanya tersedia untuk paket Pro, karena memerlukan penyesuaian teknis dan sumber daya yang lebih besar. Untuk paket Starter, kami menyarankan untuk memulai dengan setup baru untuk memastikan performa optimal.",
    },
    {
        q: "Apakah ada kontrak minimal?",
        a: "Tidak ada kontrak panjang untuk paket bulanan standar. Detail kerja sama ditentukan transparan di awal.",
    },
    {
        q: "Jika saya lupa bayar, apakah data hilang?",
        a: "Tidak langsung hilang, tapi akses akan dibatasi sampai pembayaran dilakukan. Kami menyarankan untuk segera menghubungi tim support jika mengalami kendala pembayaran agar data tetap aman.",
    },
    {
        q: "Bagaimana dengan Maintenance dan Backup?",
        a: "Kami melakukan maintenance rutin untuk memastikan performa optimal dan keamanan data. Backup dilakukan secara berkala untuk melindungi data Anda, dan kami memiliki prosedur pemulihan data yang cepat jika terjadi masalah.",
    },
];
---

<section class="section pricing-section" id="pricing" aria-labelledby="pricing-title">
    <div class="container pricing-shell">
        <div class="pricing-header reveal">
            <p class="eyebrow">Paket Layanan</p>
            <h2 class="pricing-main-title font-display" id="pricing-title">Harga jelas, tanpa biaya tersembunyi.</h2>
            <p class="pricing-subtitle">
                Semua paket sudah termasuk server khusus portal, dukungan teknis, maintanance, dan update fitur. Anda tidak perlu lagi keluar biaya untuk theme, plugin, atau optimasi performa. Kami juga menyediakan opsi kustomisasi dan integrasi untuk kebutuhan khusus di luar cakupan paket standar.
            </p>
        </div>

        <div class="pricing-cards reveal reveal-delay-1">
            {
                plans.map((plan) => (
                    <article class={`pricing-card hover-logo-overlay-target ${plan.popular ? "pricing-card-popular" : ""}`}>
                        <HoverLogoOverlay preset="interactive" logoTop="calc(var(--hlo-logo-size) * -0.14)" />
                        <div class="hover-logo-overlay-content">
                            {plan.popular && <span class="badge-popular">Pilihan Utama</span>}
                            <h3 class="plan-name font-display">{plan.name}</h3>
                            <p class="plan-desc">{plan.description}</p>
                            <div class="plan-price-wrap">
                                <span class="plan-price font-display">{plan.priceIdr}</span>
                                <span class="plan-period">{plan.period}</span>
                            </div>
                            <ul class="plan-features">
                                {plan.features.map((feature) => <li>{feature}</li>)}
                            </ul>
                            <a
                                href={`https://wa.me/6285783024799?text=${encodeURIComponent(`Halo, saya tertarik dengan paket ${plan.name} Portal Online.`)}`}
                                target="_blank"
                                rel="nofollow noopener noreferrer"
                                class={`btn ${plan.popular ? "btn-primary" : "btn-secondary"}`}
                            >
                                {plan.cta}
                            </a>
                        </div>
                    </article>
                ))
            }
        </div>

        <div class="pricing-faq reveal reveal-delay-2">
            <h3 class="faq-header font-display">Pertanyaan Umum</h3>
            <div class="faq-grid">
                {
                    faqs.map((faq) => (
                        <article class="faq-item">
                            <h4 class="faq-q">{faq.q}</h4>
                            <p class="faq-a">{faq.a}</p>
                        </article>
                    ))
                }
            </div>
        </div>
    </div>
</section>

<style>
    .pricing-section {
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .pricing-shell {
        display: grid;
        gap: 2.4rem;
    }

    .pricing-header {
        max-width: 58rem;
    }

    .pricing-main-title {
        margin-top: 0.8rem;
        font-size: clamp(2.2rem, 4.5vw, 3.9rem);
        line-height: 1.08;
    }

    .pricing-subtitle {
        margin-top: 1rem;
        color: var(--color-text-muted);
        line-height: 1.75;
        max-width: 64ch;
    }

    .pricing-cards {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
    }

    .pricing-card {
        border: 1px solid rgba(255, 255, 255, 0.13);
        border-radius: 1rem;
        padding: 1.35rem;
        background: rgba(255, 255, 255, 0.01);
        position: relative;
        overflow: hidden;
        transition:
            border-color var(--transition-fast),
            transform var(--transition-fast),
            box-shadow var(--transition-fast);
    }

    .pricing-card-popular {
        border-color: rgba(var(--color-primary), 0.34);
        background: rgba(var(--color-primary), 0.03);
    }

    .pricing-card:hover,
    .pricing-card:focus-within {
        border-color: rgba(255, 255, 255, 0.24);
        transform: translateY(-2px);
        box-shadow: 0 16px 28px rgba(3, 10, 20, 0.28);
    }

    .pricing-card-popular:hover,
    .pricing-card-popular:focus-within {
        border-color: rgba(var(--color-primary), 0.52);
        box-shadow:
            inset 0 0 0 1px rgba(var(--color-primary), 0.14),
            0 18px 30px rgba(var(--color-primary), 0.16);
    }

    .badge-popular {
        display: inline-flex;
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        font-weight: 700;
        text-transform: uppercase;
        color: rgb(var(--color-primary));
    }

    .plan-name {
        margin-top: 0.45rem;
        font-size: 2.05rem;
        line-height: 1.05;
    }

    .plan-desc {
        margin-top: 0.4rem;
        color: var(--color-text-muted);
        line-height: 1.65;
        min-height: 2.8rem;
    }

    .plan-price-wrap {
        margin-top: 0.95rem;
        display: flex;
        align-items: baseline;
        gap: 0.45rem;
    }

    .plan-price {
        font-size: 2.4rem;
        line-height: 1;
    }

    .plan-period {
        color: var(--color-text-soft);
        font-size: 0.9rem;
    }

    .plan-features {
        margin-top: 1rem;
        list-style: none;
        display: grid;
        gap: 0.5rem;
    }

    .plan-features li {
        color: var(--color-text-soft);
        font-size: 0.92rem;
        line-height: 1.6;
        position: relative;
        padding-left: 1rem;
    }

    .plan-features li::before {
        content: "";
        width: 0.35rem;
        height: 0.35rem;
        border-radius: 999px;
        background: rgba(var(--color-primary), 0.9);
        position: absolute;
        left: 0;
        top: 0.52rem;
    }

    .pricing-card .btn {
        margin-top: 1.15rem;
        width: 100%;
    }

    .pricing-faq {
        margin-top: 0.8rem;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        padding-top: 1.55rem;
    }

    .faq-header {
        font-size: 1.7rem;
        margin-bottom: 1rem;
    }

    .faq-grid {
        display: grid;
        gap: 0.85rem;
    }

    .faq-item {
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 0.85rem;
        padding: 0.95rem;
        background: rgba(255, 255, 255, 0.01);
    }

    .faq-q {
        font-size: 0.97rem;
        color: var(--color-text);
    }

    .faq-a {
        margin-top: 0.45rem;
        color: var(--color-text-soft);
        line-height: 1.65;
        font-size: 0.9rem;
    }

    @media (min-width: 980px) {
        .pricing-cards {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .faq-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @media (max-width: 767px) {
        .pricing-card {
            padding: 1.2rem;
        }

        .plan-desc {
            min-height: 0;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .pricing-card {
            transition: none;
        }

        .pricing-card:hover,
        .pricing-card:focus-within {
            transform: none;
        }
    }
</style>
