---
import HoverLogoOverlay from "./HoverLogoOverlay.astro";
import {
    billingPeriods,
    formatCompactIdr,
    getPackagePrice,
    servicePackages,
    type BillingPeriod,
} from "../data/servicePackages";

const faqs = [
    {
        q: "Aplikasi bisa langsung digunakan?",
        a: "Ya. CMS Portal Online sudah siap digunakan. Setelah akun aktif dan domain diarahkan ke server kami, Anda bisa langsung login dan mulai membuat konten. Kami juga menyediakan dokumentasi dan tutorial untuk membantu Anda memulai dengan cepat.",
    },
    {
        q: "Apakah fitur SEO sudah termasuk?",
        a: "Ya, semua paket sudah termasuk fitur optimasi SEO dasar seperti meta tag otomatis, sitemap, dan struktur URL yang ramah SEO. Paket Pro juga dilengkapi dengan analitik SEO untuk membantu anda memantau performa konten dan mendapatkan rekomendasi optimasi lebih lanjut.",
    },
    {
        q: "Apakah ada biaya tambahan?",
        a: "Tidak ada biaya tersembunyi. Semua layanan dan fitur yang termasuk dalam paket sudah dijelaskan secara transparan di awal. Biaya tambahan hanya berlaku untuk kebutuhan khusus di luar cakupan paket, yang akan didiskusikan terlebih dahulu.",
    },
    {
        q: "Apakah bisa migrasi dari WordPress?",
        a: "Migrasi dari WordPress hanya tersedia untuk paket Pro, karena memerlukan penyesuaian teknis dan sumber daya yang lebih besar. Untuk paket Starter, kami menyarankan untuk memulai dengan setup baru untuk memastikan performa optimal.",
    },
    {
        q: "Apakah ada kontrak minimal?",
        a: "Tidak ada kontrak panjang untuk paket bulanan standar. Detail kerja sama ditentukan transparan di awal.",
    },
    {
        q: "Jika saya lupa bayar, apakah data hilang?",
        a: "Tidak langsung hilang, tapi akses akan dibatasi sampai pembayaran dilakukan. Kami menyarankan untuk segera menghubungi tim support jika mengalami kendala pembayaran agar data tetap aman.",
    },
    {
        q: "Bagaimana dengan Maintenance dan Backup?",
        a: "Kami melakukan maintenance rutin untuk menjaga performa tetap optimal dan data tetap aman. Backup dilakukan secara berkala, dan kami memiliki prosedur pemulihan yang cepat jika terjadi kendala.",
    },
];

const defaultPeriod: BillingPeriod = "monthly";
---


<section class="section pricing-section" id="pricing" aria-labelledby="pricing-title" data-active-period={defaultPeriod}>
    <div class="container pricing-shell">
        <div class="pricing-block">
            <div class="pricing-header reveal">
                <p class="eyebrow">Paket Layanan</p>
                <h2 class="pricing-main-title font-display" id="pricing-title">Harga jelas, tanpa biaya tersembunyi.</h2>
                <p class="pricing-subtitle">
                    Semua paket sudah termasuk server khusus portal, dukungan teknis, maintenance, dan update fitur. Anda tidak perlu lagi mengeluarkan biaya tambahan untuk tema, plugin, atau optimasi performa. Kami juga menyediakan opsi kustomisasi dan integrasi untuk kebutuhan khusus di luar cakupan paket standar.
                </p>
                <div class="billing-toggle" aria-label="Pilih periode pembayaran">
                    {
                        Object.values(billingPeriods).map((period) => (
                            <button
                                type="button"
                                class={`billing-toggle-button ${period.id === defaultPeriod ? "active" : ""}`}
                                data-period={period.id}
                                aria-pressed={period.id === defaultPeriod ? "true" : "false"}
                            >
                                <span>{period.label}</span>
                                {period.badge && <small>{period.badge}</small>}
                            </button>
                        ))
                    }
                </div>
            </div>

            <div class="pricing-cards reveal reveal-delay-1">
                {
                    servicePackages.map((plan) => {
                        const monthlyPrice = getPackagePrice(plan, "monthly");
                        const yearlyPrice = getPackagePrice(plan, "yearly");
                        const checkoutHref = plan.checkoutEnabled
                            ? `/checkout/${plan.id}?period=${defaultPeriod}`
                            : `https://wa.me/6285783024799?text=${encodeURIComponent(`Halo, saya ingin mendiskusikan kebutuhan paket ${plan.name} Portal Online.`)}`;

                        return (
                            <article class={`pricing-card hover-logo-overlay-target ${plan.popular ? "pricing-card-popular" : ""}`}>
                                <HoverLogoOverlay preset="interactive" logoTop="calc(var(--hlo-logo-size) * -0.14)" />
                                <div class="hover-logo-overlay-content">
                                    {plan.popular && <span class="badge-popular">Pilihan Utama</span>}
                                    <h3 class="plan-name font-display">{plan.name}</h3>
                                    <p class="plan-desc">{plan.description}</p>
                                    <div class="plan-price-wrap">
                                        {monthlyPrice && yearlyPrice ? (
                                            <>
                                                <span
                                                    class="plan-price font-display"
                                                    data-monthly-price={formatCompactIdr(monthlyPrice)}
                                                    data-yearly-price={formatCompactIdr(yearlyPrice)}
                                                >
                                                    {formatCompactIdr(monthlyPrice)}
                                                </span>
                                                <span
                                                    class="plan-period"
                                                    data-monthly-period={billingPeriods.monthly.periodLabel}
                                                    data-yearly-period={billingPeriods.yearly.periodLabel}
                                                >
                                                    {billingPeriods.monthly.periodLabel}
                                                </span>
                                            </>
                                        ) : (
                                            <>
                                                <span class="plan-price font-display">Custom</span>
                                                <span class="plan-period">Sesuai kebutuhan</span>
                                            </>
                                        )}
                                    </div>
                                    {plan.checkoutEnabled && (
                                        <p class="plan-saving" data-yearly-saving="true" hidden>
                                            Bayar 10 bulan untuk 12 bulan layanan.
                                        </p>
                                    )}
                                    <ul class="plan-features">
                                        {plan.features.map((feature) => <li>{feature}</li>)}
                                    </ul>
                                    <a
                                        href={checkoutHref}
                                        target={plan.checkoutEnabled ? undefined : "_blank"}
                                        rel={plan.checkoutEnabled ? undefined : "nofollow noopener noreferrer"}
                                        data-checkout-base={plan.checkoutEnabled ? `/checkout/${plan.id}` : undefined}
                                        class={`btn ${plan.popular ? "btn-primary" : "btn-secondary"}`}
                                    >
                                        {plan.cta}
                                    </a>
                                </div>
                            </article>
                        );
                    })
                }
            </div>

            <p class="pricing-footnote reveal reveal-delay-2">
                * Paket tahunan hemat 2 bulan dan termasuk domain gratis `.id`/`.com` untuk Starter &amp; Pro.
            </p>
        </div>

        <section class="pricing-faq qa-block reveal reveal-delay-2" aria-labelledby="pricing-faq-title">
            <h3 class="faq-header font-display" id="pricing-faq-title">Pertanyaan Umum</h3>
            <div class="faq-list">
                {
                    faqs.map((faq, index) => (
                        <article class="faq-item">
                            <button
                                type="button"
                                class="faq-question"
                                id={`pricing-faq-trigger-${index}`}
                                aria-expanded="false"
                                aria-controls={`pricing-faq-panel-${index}`}
                            >
                                <span class="faq-q">{faq.q}</span>
                                <svg
                                    class="faq-icon"
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    aria-hidden="true"
                                >
                                    <path d="M6 9l6 6 6-6" />
                                </svg>
                            </button>
                            <div
                                class="faq-answer"
                                id={`pricing-faq-panel-${index}`}
                                role="region"
                                aria-labelledby={`pricing-faq-trigger-${index}`}
                            >
                                <p class="faq-a">{faq.a}</p>
                            </div>
                        </article>
                    ))
                }
            </div>
        </section>
    </div>
</section>
<style>
    .pricing-section {
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .pricing-shell {
        display: grid;
        gap: 2.4rem;
    }

    .pricing-block {
        display: grid;
        gap: 1.15rem;
    }

    .pricing-header {
        max-width: 58rem;
    }

    .pricing-main-title {
        margin-top: 0.8rem;
        font-size: clamp(2.2rem, 4.5vw, 3.9rem);
        line-height: 1.08;
    }

    .pricing-subtitle {
        margin-top: 1rem;
        color: var(--color-text-muted);
        line-height: 1.75;
        max-width: 64ch;
    }

    .billing-toggle {
        margin-top: 1.2rem;
        display: inline-flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        padding: 0.3rem;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.03);
    }

    .billing-toggle-button {
        border: 0;
        border-radius: 999px;
        padding: 0.65rem 0.95rem;
        color: var(--color-text-soft);
        background: transparent;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        font-weight: 700;
        transition:
            color var(--transition-fast),
            background var(--transition-fast);
    }

    .billing-toggle-button small {
        color: inherit;
        font-size: 0.72rem;
        font-weight: 600;
        opacity: 0.78;
    }

    .billing-toggle-button.active {
        color: rgb(var(--color-background));
        background: rgb(var(--color-primary));
    }

    .pricing-cards {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
    }

    .pricing-card {
        border: 1px solid rgba(255, 255, 255, 0.13);
        border-radius: 1rem;
        padding: 1.35rem;
        background: rgba(255, 255, 255, 0.01);
        position: relative;
        overflow: hidden;
        transition:
            border-color var(--transition-fast),
            transform var(--transition-fast),
            box-shadow var(--transition-fast);
    }

    .pricing-card-popular {
        border-color: rgba(var(--color-primary), 0.34);
        background: rgba(var(--color-primary), 0.03);
    }

    .pricing-card:hover,
    .pricing-card:focus-within {
        border-color: rgba(255, 255, 255, 0.24);
        transform: translateY(-2px);
        box-shadow: 0 16px 28px rgba(3, 10, 20, 0.28);
    }

    .pricing-card-popular:hover,
    .pricing-card-popular:focus-within {
        border-color: rgba(var(--color-primary), 0.52);
        box-shadow:
            inset 0 0 0 1px rgba(var(--color-primary), 0.14),
            0 18px 30px rgba(var(--color-primary), 0.16);
    }

    .badge-popular {
        display: inline-flex;
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        font-weight: 700;
        text-transform: uppercase;
        color: rgb(var(--color-primary));
    }

    .plan-name {
        margin-top: 0.45rem;
        font-size: 2.05rem;
        line-height: 1.05;
    }

    .plan-desc {
        margin-top: 0.4rem;
        color: var(--color-text-muted);
        line-height: 1.65;
        min-height: 2.8rem;
    }

    .plan-price-wrap {
        margin-top: 0.95rem;
        display: flex;
        align-items: baseline;
        gap: 0.45rem;
    }

    .plan-price {
        font-size: 2.4rem;
        line-height: 1;
    }

    .plan-period {
        color: var(--color-text-soft);
        font-size: 0.9rem;
    }

    .plan-saving {
        margin-top: 0.55rem;
        color: rgb(var(--color-primary));
        font-size: 0.84rem;
        font-weight: 700;
        line-height: 1.5;
    }

    .plan-features {
        margin-top: 1rem;
        list-style: none;
        display: grid;
        gap: 0.5rem;
    }

    .plan-features li {
        color: var(--color-text-soft);
        font-size: 0.92rem;
        line-height: 1.6;
        position: relative;
        padding-left: 1rem;
    }

    .plan-features li::before {
        content: "";
        width: 0.35rem;
        height: 0.35rem;
        border-radius: 999px;
        background: rgba(var(--color-primary), 0.9);
        position: absolute;
        left: 0;
        top: 0.52rem;
    }

    .pricing-card .btn {
        margin-top: 1.15rem;
        width: 100%;
    }

    .pricing-footnote {
        margin-top: 0.2rem;
        color: var(--color-text-soft);
        font-size: 0.84rem;
        line-height: 1.6;
    }

    .pricing-faq {
        margin-top: 0.8rem;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        padding-top: 1.55rem;
    }

    .faq-header {
        font-size: 1.7rem;
        margin-bottom: 1rem;
    }

    .faq-list {
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
    }

    .faq-item {
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 0.85rem;
        background: rgba(255, 255, 255, 0.01);
        overflow: hidden;
        transition: border-color var(--transition-fast);
    }

    .faq-item:hover {
        border-color: rgba(var(--color-primary), 0.34);
    }

    .faq-item.open {
        border-color: rgba(var(--color-primary), 0.45);
    }

    .faq-question {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.9rem;
        padding: 0.95rem;
        border: none;
        background: transparent;
        cursor: pointer;
        text-align: left;
        color: var(--color-text);
    }

    .faq-q {
        font-size: 0.97rem;
        font-weight: 600;
        line-height: 1.5;
    }

    .faq-icon {
        flex-shrink: 0;
        color: var(--color-text-muted);
        transition:
            transform var(--transition-fast),
            color var(--transition-fast);
    }

    .faq-item.open .faq-icon {
        transform: rotate(180deg);
        color: rgb(var(--color-primary));
    }

    .faq-answer {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.28s ease;
    }

    .faq-item.open .faq-answer {
        max-height: 18rem;
    }

    .faq-a {
        margin: 0;
        padding: 0 0.95rem 0.95rem;
        color: var(--color-text-soft);
        line-height: 1.65;
        font-size: 0.9rem;
    }

    @media (min-width: 980px) {
        .pricing-cards {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @media (max-width: 767px) {
        .pricing-card {
            padding: 1.2rem;
        }

        .plan-desc {
            min-height: 0;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .pricing-card {
            transition: none;
        }

        .pricing-card:hover,
        .pricing-card:focus-within {
            transform: none;
        }

        .faq-answer {
            transition: none;
        }

        .faq-icon {
            transition: none;
        }
    }
</style>

<script is:inline>
    (function () {
        function initPricingFAQAccordion() {
            const root = document.querySelector(".pricing-section");
            if (!root) return;

            const faqItems = root.querySelectorAll(".pricing-faq .faq-item");
            faqItems.forEach((item) => {
                const trigger = item.querySelector(".faq-question");
                if (!trigger) return;

                trigger.onclick = () => {
                    const isOpen = item.classList.contains("open");

                    faqItems.forEach((otherItem) => {
                        const otherTrigger = otherItem.querySelector(".faq-question");
                        otherItem.classList.remove("open");
                        otherTrigger?.setAttribute("aria-expanded", "false");
                    });

                    if (!isOpen) {
                        item.classList.add("open");
                        trigger.setAttribute("aria-expanded", "true");
                    }
                };
            });
        }

        function initBillingToggle() {
            const root = document.querySelector(".pricing-section");
            if (!root) return;

            const buttons = root.querySelectorAll(".billing-toggle-button");
            const priceNodes = root.querySelectorAll(".plan-price[data-monthly-price]");
            const periodNodes = root.querySelectorAll(".plan-period[data-monthly-period]");
            const savingNodes = root.querySelectorAll("[data-yearly-saving]");
            const checkoutLinks = root.querySelectorAll("[data-checkout-base]");

            function setPeriod(period) {
                const safePeriod = period === "yearly" ? "yearly" : "monthly";
                root.setAttribute("data-active-period", safePeriod);

                buttons.forEach((button) => {
                    const active = button.getAttribute("data-period") === safePeriod;
                    button.classList.toggle("active", active);
                    button.setAttribute("aria-pressed", active ? "true" : "false");
                });

                priceNodes.forEach((node) => {
                    const value = node.getAttribute(`data-${safePeriod}-price`);
                    if (value) node.textContent = value;
                });

                periodNodes.forEach((node) => {
                    const value = node.getAttribute(`data-${safePeriod}-period`);
                    if (value) node.textContent = value;
                });

                savingNodes.forEach((node) => {
                    node.hidden = safePeriod !== "yearly";
                });

                checkoutLinks.forEach((link) => {
                    const base = link.getAttribute("data-checkout-base");
                    if (base) link.setAttribute("href", `${base}?period=${safePeriod}`);
                });
            }

            buttons.forEach((button) => {
                button.addEventListener("click", () => {
                    setPeriod(button.getAttribute("data-period"));
                });
            });
        }

        function initPricing() {
            initPricingFAQAccordion();
            initBillingToggle();
        }

        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", initPricing);
        } else {
            initPricing();
        }

        document.addEventListener("astro:page-load", initPricing);
    })();
</script>
