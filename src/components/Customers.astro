---
const customers = [
    { src: "/images/customer/portal-berita-bilah-news.avif", alt: "Logo Bilah News" },
    { src: "/images/customer/portal-berita-indikator-media.avif", alt: "Logo Indikator Media" },
    { src: "/images/customer/portal-berita-kabar-siang.avif", alt: "Logo Kabar Siang" },
    { src: "/images/customer/portal-berita-online-rasionalis.avif", alt: "Logo Rasionalis" },
    { src: "/images/customer/portal-berita-swararakjatmerdeka.avif", alt: "Logo Swara Rakyat Merdeka" },
    { src: "/images/customer/website -perusahaan-jasaku.avif", alt: "Logo Jasaku" },
];
---

<section class="section proof-strip" aria-labelledby="proof-title">
    <div class="container">
        <p class="proof-kicker eyebrow reveal" id="proof-title">
            Dipercaya portal berita dan brand digital di berbagai kota
        </p>

        <div class="proof-grid reveal reveal-delay-1" aria-label="Portofolio klien Portal Online">
            {
                customers.map((customer) => (
                    <div class="proof-logo-item">
                        <img
                            src={customer.src}
                            alt={customer.alt}
                            loading="lazy"
                            decoding="async"
                            width="140"
                            height="52"
                            class="proof-logo"
                        />
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    .proof-strip {
        padding-top: 1.5rem;
        padding-bottom: 3.4rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .proof-kicker {
        text-align: left;
        margin-bottom: 2rem;
    }

    .proof-grid {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-start;
        align-items: center;
        gap: 1.5rem 2.5rem;
        max-width: 74rem;
    }

    .proof-logo-item {
        opacity: 0.74;
        filter: saturate(0.5) grayscale(0.6);
        transition: opacity var(--transition-fast), filter var(--transition-fast);
    }

    .proof-logo-item:hover {
        opacity: 0.82;
        filter: saturate(0.58) grayscale(0.45);
    }

    .proof-logo {
        height: 48px;
        width: auto;
        object-fit: contain;
        border-radius: 0.45rem;
    }

    @media (min-width: 768px) {
        .proof-grid {
            gap: 1.9rem 3.1rem;
        }

        .proof-logo {
            height: 56px;
        }
    }
</style>
