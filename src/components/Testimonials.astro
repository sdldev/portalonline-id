---
const testimonials = [
    {
        name: "Zainal Asikin",
        role: "Pimred SWM, Jurnalis Madya AJI",
        avatar: "/images/testimoni/zainal-asikin.avif",
        content:
            "Portal Online membantu kami merapikan pengelolaan berita dan membuat tampilan situs terasa jauh lebih siap bersaing. Yang paling terasa justru kombinasi performa, dashboard, dan kualitas presentasinya.",
        featured: true,
    },
    {
        name: "Ridwan Saleh, S.H.",
        role: "Pimpinan Jasaku.co.id",
        avatar: "/images/testimoni/ridwan-saleh-sh.avif",
        content:
            "Saya butuh partner yang memahami tujuan bisnis, lalu menerjemahkannya menjadi website yang benar-benar membantu perkembangan usaha. Itu yang saya dapatkan.",
        featured: false,
    },
    {
        name: "Iskandar Yuan",
        role: "Pimpinan Rasionalis",
        avatar: "/images/testimoni/iskandar-yuan.avif",
        content:
            "Tim kami terbantu karena alur kerja editorial jadi sangat rapi. Ini sistem yang memang dipikirkan untuk dipakai setiap hari oleh redaksi.",
        featured: false,
    },
];
---

<section class="section testi-section" aria-labelledby="testimonials-title">
    <div class="container testi-shell">
        <div class="testi-header reveal">
            <p class="eyebrow">Testimoni</p>
            <h2 class="section-title" id="testimonials-title">
                Dipercaya oleh pemimpin redaksi dan pemilik bisnis.
            </h2>
        </div>

        <div class="testi-grid">
            {
                testimonials.map((item, index) => (
                    <article class={`testi-card reveal reveal-delay-${index + 1} ${item.featured ? "testi-card-featured" : "testi-card-standard"}`}>
                        <div class="testi-content-wrapper">
                            <p class="testi-text">&ldquo;{item.content}&rdquo;</p>
                        </div>

                        <div class="testi-author">
                            <div class="testi-avatar">
                                <img src={item.avatar} alt={`Foto ${item.name}`} width="56" height="56" loading="lazy" />
                            </div>
                            <div class="testi-author-info">
                                <p class="testi-name">{item.name}</p>
                                <p class="testi-role">{item.role}</p>
                            </div>
                        </div>
                    </article>
                ))
            }
        </div>
    </div>
</section>

<style>
    .testi-section {
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .testi-shell {
        display: flex;
        flex-direction: column;
        gap: 2.3rem;
    }

    .testi-header {
        max-width: 58rem;
    }

    .testi-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
    }

    .testi-card {
        padding: 1.5rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 1rem;
        background: rgba(255, 255, 255, 0.006);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 1.5rem;
    }

    .testi-card-featured {
        background: rgba(255, 255, 255, 0.015);
        border-color: rgba(255, 255, 255, 0.16);
        padding: 1.8rem;
    }

    .testi-text {
        line-height: 1.72;
        color: var(--color-text);
        font-size: 1.06rem;
    }

    .testi-card-featured .testi-text {
        font-size: 1.24rem;
        line-height: 1.66;
    }

    .testi-author {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        padding-top: 1.1rem;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .testi-avatar {
        width: 3.2rem;
        height: 3.2rem;
        border-radius: 999px;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.08);
    }

    .testi-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .testi-name {
        font-size: 0.98rem;
        color: var(--color-text);
        font-weight: 600;
    }

    .testi-role {
        margin-top: 0.2rem;
        color: var(--color-text-soft);
        font-size: 0.84rem;
    }

    @media (min-width: 980px) {
        .testi-grid {
            grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
            grid-template-rows: auto auto;
            gap: 1rem;
        }

        .testi-card-featured {
            grid-row: 1 / 3;
        }
    }
</style>
