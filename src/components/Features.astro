---
import HoverLogoOverlay from "./HoverLogoOverlay.astro";

const pillars = [
    {
        eyebrow: "Server dan performa",
        title: "Server khusus, optimasi khusus, performa maksimal",
        description:
            "Kami menggunakan server khusus dengan konfigurasi yang dioptimalkan untuk CMS portal berita. Hasilnya: kecepatan akses yang konsisten, waktu muat halaman yang cepat, dan pengalaman pengguna yang mulus tanpa gangguan teknis.",
    },
    {
        eyebrow: "Desain simple dan modern",
        title: "Desain yang dirancang khusus media online",
        description:
            "Tampilan simple dan modern yang dirancang khusus untuk media online, memastikan pembaca fokus pada konten tanpa gangguan visual. Desain ini juga memudahkan redaksi dalam mengelola dan menampilkan berita dengan cara yang menarik dan mudah dinavigasi.",
    },
    {
        eyebrow: "SEO dan Keamanan",
        title: "Fondasi SEO dan keamanan yang terintegrasi",
        description:
            "CMS kami dibangun sudah memiliki SEO yang kuat, tidak perlu tambahan plugin atau modifikasi. Keamanan juga dirancang untuk melindungi situs dari serangan siber, memastikan data dan konten tetap aman",
    },
];

---

<section class="section features-section section-frame" id="why-choose" aria-labelledby="why-choose-title">
    <div class="container features-shell">
        <div class="features-intro reveal">
            <p class="eyebrow">Fitur Layanan</p>
            <h2 class="features-main-title font-display" id="why-choose-title">
                CMS PORTAL ONLINE Siap Pakai, Siap Tumbuh, Siap Bersaing.
            </h2>
            <p class="features-intro-copy">
                Fokus kami sederhana: anda fokus pada konten dan strategi, kami pastikan fondasi teknisnya kuat, cepat, dan mudah dikembangkan. Tidak perlu pusing soal hosting, optimasi, atau fitur teknis lainnya. Kami yang urus, anda yang fokus ke bisnis.
            </p>
        </div>

        <div class="features-grid">
            {
                pillars.map((pillar, index) => (
                    <article class={`feature-item hover-logo-overlay-target reveal reveal-delay-${index + 1}`}>
                        <HoverLogoOverlay
                            preset="informational"
                            logoTop="calc(var(--hlo-logo-size) * -0.14)"
                            logoRight="calc(var(--hlo-logo-size) * -0.14)"
                            logoSize="4.8rem"
                            hoverOpacity={0.18}
                        />
                        <div class="hover-logo-overlay-content">
                            <p class="feature-eyebrow">{pillar.eyebrow}</p>
                            <h3 class="feature-title font-display">{pillar.title}</h3>
                            <p class="feature-text">{pillar.description}</p>
                        </div>
                    </article>
                ))
            }
        </div>
    </div>
</section>

<style>
    .features-section {
        background: rgba(255, 255, 255, 0.01);
    }

    .features-shell {
        display: grid;
        gap: 3.4rem;
        max-width: 76rem;
    }

    .features-intro {
        max-width: 62rem;
    }

    .features-main-title {
        margin-top: 0.9rem;
        font-size: clamp(2.05rem, 4vw, 3.6rem);
        line-height: 1.08;
    }

    .features-intro-copy {
        margin-top: 1rem;
        color: var(--color-text-muted);
        max-width: 66ch;
        line-height: 1.75;
    }

    .features-grid {
        display: grid;
        gap: 1.4rem;
    }

    .feature-item {
        padding: 1.35rem 1.15rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 1rem;
        background: rgba(255, 255, 255, 0.012);
        overflow: hidden;
        min-height: 100%;
    }

    .feature-eyebrow {
        color: rgb(var(--color-primary));
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.13em;
        text-transform: uppercase;
    }

    .feature-title {
        margin-top: 0.6rem;
        font-size: 1.95rem;
        line-height: 1.12;
    }

    .feature-text {
        margin-top: 0.8rem;
        color: var(--color-text-muted);
        line-height: 1.75;
    }

    @media (min-width: 900px) {
        .features-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 1.6rem;
        }

        .feature-item {
            padding: 1.5rem 1.3rem;
        }
    }
</style>
