---
const pillars = [
    {
        eyebrow: "Arsitektur dan performa",
        title: "Fondasi yang siap trafik dan siap berkembang",
        description:
            "Kami membangun struktur frontend, CMS, dan server yang rapi sejak awal. Hasilnya bukan hanya cepat saat peluncuran, tapi tetap stabil ketika volume konten dan pembaca bertambah.",
    },
    {
        eyebrow: "Design direction dan identitas",
        title: "Tampilan terasa kredibel sejak detik pertama",
        description:
            "Tipografi, ritme layout, dan komposisi visual kami rancang spesifik untuk karakter brand Anda. Bukan template generik yang sekadar diganti warna.",
    },
    {
        eyebrow: "Operasional dan pendampingan",
        title: "Diskusi teknis langsung dengan developer",
        description:
            "Setiap keputusan penting, dari struktur konten sampai optimasi teknis, dibahas langsung tanpa rantai perantara. Alur kerja jadi lebih cepat dan jelas.",
    },
];

const detailItems = [
    {
        title: "Fondasi SEO",
        text: "Struktur heading, metadata, internal link, dan schema disiapkan sebagai bagian dari fondasi website.",
    },
    {
        title: "Alur CMS",
        text: "Alur terbit artikel dan manajemen redaksi dirancang untuk penggunaan harian, bukan sekadar demo presentasi.",
    },
    {
        title: "Akses Developer Langsung",
        text: "Butuh perubahan teknis, evaluasi performa, atau ide baru: Anda berdiskusi langsung dengan developer yang membangunnya.",
    },
];
---

<section class="section features-section section-frame" id="why-choose" aria-labelledby="why-choose-title">
    <div class="container features-shell">
        <div class="features-intro reveal">
            <p class="eyebrow">Pendekatan Kami</p>
            <h2 class="features-main-title font-display" id="why-choose-title">
                Kami tidak menjual setup instan. Kami membangun sistem publikasi yang tahan dipakai bertahun-tahun.
            </h2>
            <p class="features-intro-copy">
                Fokus kami sederhana: performa yang sehat, presentasi yang kredibel, dan proses editorial yang nyaman untuk tim Anda.
            </p>
        </div>

        <div class="features-grid">
            {
                pillars.map((pillar, index) => (
                    <article class={`feature-item reveal reveal-delay-${index + 1}`}>
                        <p class="feature-eyebrow">{pillar.eyebrow}</p>
                        <h3 class="feature-title font-display">{pillar.title}</h3>
                        <p class="feature-text">{pillar.description}</p>
                    </article>
                ))
            }
        </div>

        <div class="detail-strip-wrapper reveal reveal-delay-2" aria-label="Detail pilar teknis">
            <div class="detail-grid">
                {
                    detailItems.map((item) => (
                        <article class="detail-card">
                            <h3 class="detail-title">{item.title}</h3>
                            <p class="detail-text">{item.text}</p>
                        </article>
                    ))
                }
            </div>
        </div>
    </div>
</section>

<style>
    .features-section {
        background: rgba(255, 255, 255, 0.01);
    }

    .features-shell {
        display: grid;
        gap: 3.4rem;
        max-width: 76rem;
    }

    .features-intro {
        max-width: 62rem;
    }

    .features-main-title {
        margin-top: 0.9rem;
        font-size: clamp(2.05rem, 4vw, 3.6rem);
        line-height: 1.08;
    }

    .features-intro-copy {
        margin-top: 1rem;
        color: var(--color-text-muted);
        max-width: 66ch;
        line-height: 1.75;
    }

    .features-grid {
        display: grid;
        gap: 1.4rem;
    }

    .feature-item {
        padding: 1.2rem 0;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .feature-eyebrow {
        color: rgb(var(--color-primary));
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.13em;
        text-transform: uppercase;
    }

    .feature-title {
        margin-top: 0.6rem;
        font-size: 1.95rem;
        line-height: 1.12;
    }

    .feature-text {
        margin-top: 0.8rem;
        color: var(--color-text-muted);
        line-height: 1.75;
    }

    .detail-strip-wrapper {
        padding-top: 2.2rem;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .detail-grid {
        display: grid;
        gap: 0.35rem;
    }

    .detail-card {
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        padding: 0.95rem 0 1.05rem;
        background: transparent;
    }

    .detail-title {
        font-size: 0.9rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--color-text);
    }

    .detail-text {
        margin-top: 0.55rem;
        color: var(--color-text-soft);
        line-height: 1.65;
        font-size: 0.92rem;
    }

    @media (min-width: 900px) {
        .features-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 1.6rem;
        }

        .feature-item {
            border-top: none;
            padding: 0 1.25rem 0 0;
            border-right: 1px solid rgba(255, 255, 255, 0.08);
        }

        .feature-item:last-child {
            border-right: none;
        }

        .detail-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 1.2rem;
        }

        .detail-card {
            border-top: none;
            border-right: 1px solid rgba(255, 255, 255, 0.1);
            padding: 0 1rem 0 0;
        }

        .detail-card:last-child {
            border-right: none;
        }
    }
</style>
