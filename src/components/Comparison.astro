---
import HoverLogoOverlay from "./HoverLogoOverlay.astro";
import { getCollection, selectFeaturedEntry } from "../utils/collections";

const articleCollection = await getCollection("article");
const featuredArticle = selectFeaturedEntry(articleCollection);
---

<section class="section comparison-section" id="comparison" aria-labelledby="comparison-title">
    <div class="container comparison-shell">
        <div class="comparison-copy reveal">
            <p class="eyebrow">Portofolio Pilihan</p>
            <h2 class="section-title" id="comparison-title">
                Hasil nyata lebih penting dari janji manis.
            </h2>
            <p class="section-subtitle comparison-subtitle">
                Kami menempatkan hasil nyata sebagai pusat kerja: performa, kejelasan struktur informasi,
                dan pengalaman baca yang nyaman untuk audiens Anda.
            </p>
        </div>

        {
            featuredArticle ? (
                <a href={`/article/${featuredArticle.id}`} class="proof-card hover-logo-overlay-target reveal reveal-delay-1">
                    <HoverLogoOverlay preset="interactive" logoTop="calc(var(--hlo-logo-size) * -0.14)" logoSize="5.4rem" />
                    <div class="hover-logo-overlay-content">
                        <div class="proof-card-media">
                            {
                                featuredArticle.data.image ? (
                                    <img
                                        src={featuredArticle.data.image}
                                        alt={featuredArticle.data.title}
                                        loading="lazy"
                                    />
                                ) : (
                                    <div class="proof-placeholder" aria-hidden="true"></div>
                                )
                            }
                        </div>

                        <div class="proof-card-content">
                            <div class="proof-meta">
                                <span class="proof-tag">Artikel Unggulan</span>
                                <time class="proof-date">
                                    {new Date(featuredArticle.data.date).toLocaleDateString("id-ID", {
                                        year: "numeric",
                                        month: "short",
                                        day: "numeric",
                                    })}
                                </time>
                            </div>

                            <h3 class="proof-title font-display">{featuredArticle.data.title}</h3>
                            {
                                featuredArticle.data.description && (
                                    <p class="proof-desc">{featuredArticle.data.description}</p>
                                )
                            }

                            <div class="proof-topic-list">
                                <span class="proof-topic">portal berita</span>
                                <span class="proof-topic">seo</span>
                                <span class="proof-topic">alur cms</span>
                            </div>
                        </div>
                    </div>
                </a>
            ) : (
                <article class="proof-card proof-card-empty hover-logo-overlay-target reveal reveal-delay-1">
                    <HoverLogoOverlay preset="informational" logoTop="calc(var(--hlo-logo-size) * -0.14)" logoSize="5rem" hoverOpacity={0.16} />
                    <div class="hover-logo-overlay-content">
                        <div class="proof-card-content">
                            <p class="proof-desc">
                                Konten artikel unggulan belum tersedia. Tambahkan artikel baru pada koleksi `article`
                                untuk menampilkan studi hasil kerja secara otomatis.
                            </p>
                        </div>
                    </div>
                </article>
            )
        }
    </div>
</section>

<style>
    .comparison-section {
        padding-top: 4.8rem;
        padding-bottom: 5.5rem;
    }

    .comparison-shell {
        display: grid;
        gap: 2.35rem;
    }

    .comparison-copy {
        max-width: 58rem;
    }

    .comparison-subtitle {
        max-width: 52rem;
    }

    .proof-card {
        display: grid;
        gap: 0;
        border: 1px solid rgba(255, 255, 255, 0.11);
        border-radius: 1.25rem;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.012);
        transition: border-color var(--transition-fast), transform var(--transition-fast);
    }

    .proof-card:focus-visible {
        outline: 2px solid rgba(var(--color-primary), 0.85);
        outline-offset: 2px;
    }

    .proof-card:hover {
        border-color: rgba(255, 255, 255, 0.24);
        transform: translateY(-2px);
    }

    .proof-card-media {
        min-height: 300px;
        background: rgba(255, 255, 255, 0.014);
    }

    .proof-card-media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .proof-placeholder {
        width: 100%;
        min-height: 300px;
        background:
            linear-gradient(130deg, rgba(var(--color-primary), 0.15), transparent),
            rgba(255, 255, 255, 0.02);
    }

    .proof-card-content {
        padding: 1.4rem 1.35rem 1.55rem;
    }

    .proof-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-bottom: 0.85rem;
    }

    .proof-tag {
        font-size: 0.7rem;
        letter-spacing: 0.11em;
        text-transform: uppercase;
        color: rgb(var(--color-primary));
        font-weight: 700;
    }

    .proof-date {
        font-size: 0.8rem;
        color: var(--color-text-soft);
    }

    .proof-title {
        font-size: clamp(1.7rem, 3vw, 2.5rem);
        line-height: 1.07;
        text-wrap: balance;
    }

    .proof-desc {
        margin-top: 0.8rem;
        color: var(--color-text-muted);
        line-height: 1.7;
    }

    .proof-topic-list {
        margin-top: 1.15rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
    }

    .proof-topic {
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 999px;
        font-size: 0.76rem;
        color: var(--color-text-soft);
        padding: 0.25rem 0.6rem;
        text-transform: lowercase;
    }

    .proof-card-empty {
        min-height: 180px;
        display: flex;
        align-items: center;
    }

    @media (min-width: 960px) {
        .proof-card {
            grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
        }

        .proof-card-content {
            padding: 1.75rem 1.7rem 1.8rem;
        }
    }

    @media (max-width: 767px) {
        .comparison-section {
            padding-top: 4.3rem;
            padding-bottom: 4.8rem;
        }

        .proof-card-media,
        .proof-placeholder {
            min-height: 210px;
        }
    }
</style>
