<style>
    .cta-section {
        position: relative;
        overflow: hidden;
    }

    .cta-card {
        position: relative;
        border-radius: 2rem;
        padding: 4rem 2rem;
        text-align: center;
        background: rgba(15, 23, 42, 0.8);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        overflow: hidden;
    }

    /* Glow Effects */
    .cta-glow {
        position: absolute;
        border-radius: 50%;
        filter: blur(100px);
        pointer-events: none;
        opacity: 0.4;
    }

    .cta-glow-1 {
        width: 400px;
        height: 400px;
        top: -120px;
        left: -80px;
        background: rgba(var(--color-primary), 0.3);
    }

    .cta-glow-2 {
        width: 350px;
        height: 350px;
        bottom: -100px;
        right: -60px;
        background: rgba(var(--color-accent), 0.25);
    }

    .cta-inner {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
    }

    .cta-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        background: rgba(var(--color-primary), 0.1);
        border: 1px solid rgba(var(--color-primary), 0.2);
        border-radius: 9999px;
        font-size: 0.8125rem;
        font-weight: 600;
        color: rgb(var(--color-primary));
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .cta-title {
        font-size: clamp(1.75rem, 4vw, 2.75rem);
        font-weight: 800;
        line-height: 1.2;
        color: var(--color-text);
        max-width: 600px;
    }

    .cta-desc {
        font-size: 1.0625rem;
        color: var(--color-text-muted);
        line-height: 1.7;
        max-width: 520px;
        margin: 0;
    }

    .cta-actions {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-top: 0.5rem;
        flex-wrap: wrap;
        justify-content: center;
    }

    .cta-btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.625rem;
        padding: 0.875rem 2rem;
        background: linear-gradient(
            135deg,
            rgb(var(--color-primary)),
            rgb(var(--color-accent))
        );
        color: white;
        font-size: 1rem;
        font-weight: 600;
        border-radius: 0.75rem;
        box-shadow: 0 4px 20px rgba(var(--color-primary), 0.4);
        transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
        text-decoration: none;
    }

    .cta-btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 30px rgba(var(--color-primary), 0.5);
    }

    .cta-btn-secondary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.875rem 1.75rem;
        background: rgba(255, 255, 255, 0.06);
        color: var(--color-text);
        font-size: 1rem;
        font-weight: 600;
        border-radius: 0.75rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
        text-decoration: none;
    }

    .cta-btn-secondary:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.2);
        transform: translateY(-2px);
    }

    .cta-note {
        font-size: 0.8125rem;
        color: var(--color-text-subtle);
        margin: 0;
        letter-spacing: 0.01em;
    }

    @media (max-width: 640px) {
        .cta-card {
            padding: 3rem 1.5rem;
            border-radius: 1.5rem;
        }

        .cta-actions {
            flex-direction: column;
            width: 100%;
        }

        .cta-btn-primary,
        .cta-btn-secondary {
            width: 100%;
            justify-content: center;
        }

        .hide-mobile {
            display: none;
        }
    }
</style>

<script>
    function initCtaReveal() {
        const cta = document.querySelector<HTMLElement>(".cta-section .reveal");
        if (!cta) return;

        const obs = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("reveal-visible");
                        obs.unobserve(entry.target);
                    }
                });
            },
            { threshold: 0.15, rootMargin: "0px 0px -40px 0px" },
        );

        cta.classList.remove("reveal-visible");
        obs.observe(cta);
    }

    document.addEventListener("DOMContentLoaded", initCtaReveal);
    document.addEventListener("astro:page-load", initCtaReveal);
</script>
