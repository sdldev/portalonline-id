---
import HoverLogoOverlay from "./HoverLogoOverlay.astro";
---

<section class="section cta-section" aria-labelledby="cta-title">
    <div class="container cta-shell">
        <div class="cta-card hover-logo-overlay-target reveal reveal-delay-1">
            <HoverLogoOverlay preset="interactive" logoTop="calc(var(--hlo-logo-size) * -0.14)" logoSize="6rem" hoverOpacity={0.2} />
            <div class="hover-logo-overlay-content">
                <p class="eyebrow">Konsultasi Gratis</p>
                <h2 class="cta-title font-display" id="cta-title">
                    Siap meluncurkan portal yang lebih rapi dikelola dan lebih meyakinkan di mata audiens?
                </h2>
                <p class="cta-desc">
                    Ceritakan kebutuhan redaksi atau bisnis Anda. Kami bantu memetakan struktur, desain, dan langkah implementasi yang realistis.
                </p>

                <a
                    href="https://wa.me/6285783024799?text=Halo%2C%20saya%20ingin%20konsultasi%20gratis%20tentang%20Portal%20Online."
                    target="_blank"
                    rel="nofollow noopener noreferrer"
                    class="btn btn-primary"
                >
                    Mulai Diskusi via WhatsApp
                </a>
                <p class="cta-note">Respons awal pada jam kerja biasanya kurang dari 1 jam.</p>
            </div>
        </div>
    </div>
</section>

<style>
    .cta-section {
        padding-top: 4.4rem;
        padding-bottom: 6.1rem;
    }

    .cta-shell {
        max-width: 1140px;
    }

    .cta-card {
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 1.2rem;
        background: rgba(255, 255, 255, 0.012);
        padding: 2.2rem 1.2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.05rem;
        text-align: center;
    }

    .cta-title {
        font-size: clamp(2rem, 4vw, 3.3rem);
        line-height: 1.08;
        max-width: 18ch;
    }

    .cta-desc {
        color: var(--color-text-muted);
        max-width: 56ch;
        line-height: 1.75;
    }

    .cta-note {
        font-size: 0.82rem;
        color: var(--color-text-soft);
    }

    @media (min-width: 768px) {
        .cta-card {
            padding: 3rem 2.1rem;
        }
    }

    @media (max-width: 767px) {
        .cta-card .btn {
            width: 100%;
        }
    }
</style>
