---
import { billingPeriods, type BillingPeriod, type ServicePackage } from "../../data/servicePackages";

interface Props {
    servicePackage: ServicePackage;
    period: BillingPeriod;
    hasPaymentError: boolean;
    hasValidationError: boolean;
}

const { servicePackage, period, hasPaymentError, hasValidationError } = Astro.props;
const billingPeriod = billingPeriods[period];
const whatsappHelpUrl = `https://wa.me/6285783024799?text=${encodeURIComponent(
    `Halo, saya butuh bantuan checkout paket ${servicePackage.name} ${billingPeriod.label} Portal Online.`,
)}`;
---

<form class="checkout-form" method="post" action="/api/duitku/create-payment" data-checkout-form novalidate={false}>
    <input type="hidden" name="packageId" value={servicePackage.id} />
    <input type="hidden" name="period" value={period} />

    <div class="checkout-form-header">
        <h2 class="font-display">Data kontak</h2>
        <p>Lengkapi data wajib untuk melanjutkan pembayaran.</p>
    </div>

    {
        (hasPaymentError || hasValidationError) && (
            <p class="checkout-alert" role="alert">
                {hasValidationError
                    ? "Periksa kembali data wajib sebelum lanjut."
                    : "Pembayaran belum dapat dibuat. Coba lagi atau hubungi WhatsApp."}
            </p>
        )
    }

    <div class="checkout-field-grid">
        <label class="checkout-field">
            <span>Nama lengkap <strong>Wajib</strong></span>
            <input name="name" type="text" autocomplete="name" minlength="2" placeholder="Nama sesuai kontak" required />
        </label>

        <label class="checkout-field">
            <span>Email <strong>Wajib</strong></span>
            <input name="email" type="email" autocomplete="email" placeholder="nama@email.com" required />
        </label>

        <label class="checkout-field">
            <span>Nomor WhatsApp <strong>Wajib</strong></span>
            <input
                name="phoneNumber"
                type="tel"
                autocomplete="tel"
                inputmode="tel"
                minlength="8"
                placeholder="08xxxxxxxxxx"
                aria-describedby="phone-help"
                required
            />
            <small id="phone-help">Gunakan nomor aktif.</small>
        </label>

        <label class="checkout-field">
            <span>Nama media / organisasi <strong>Wajib</strong></span>
            <input name="organizationName" type="text" minlength="2" placeholder="Nama media Anda" required />
        </label>
    </div>

    <div class="checkout-optional-fields" aria-label="Detail opsional">
        <div class="checkout-optional-title">
            <strong>Detail opsional</strong>
            <span>Bisa dilengkapi nanti</span>
        </div>

        <div class="checkout-field-grid">
            <label class="checkout-field checkout-field-wide">
                <span>Domain saat ini / domain pilihan <small>Opsional</small></span>
                <input name="domain" type="text" placeholder="contoh: namamedia.id" />
            </label>

            <label class="checkout-field checkout-field-wide">
                <span>Catatan kebutuhan <small>Opsional</small></span>
                <textarea name="notes" rows="3" placeholder="Contoh: migrasi artikel, setup redaksi, atau domain baru."></textarea>
            </label>
        </div>
    </div>

    <button class="btn btn-primary checkout-submit" type="submit">
        <span>Lanjutkan ke Pembayaran</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
        </svg>
    </button>

    <div class="checkout-payment-note">
        <strong>Pembayaran diproses melalui Duitku Sandbox.</strong>
        <span>Status akhir diverifikasi oleh Duitku.</span>
    </div>

    <p class="checkout-help">
        Butuh bantuan? <a href={whatsappHelpUrl} target="_blank" rel="nofollow noopener noreferrer">Hubungi WhatsApp</a>.
    </p>
</form>
