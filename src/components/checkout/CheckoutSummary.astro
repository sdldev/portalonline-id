---
import { billingPeriods, formatIdr, type BillingPeriod, type ServicePackage } from "../../data/servicePackages";

interface Props {
    servicePackage: ServicePackage;
    period: BillingPeriod;
    price: number;
}

const { servicePackage, period, price } = Astro.props;
const billingPeriod = billingPeriods[period];
const visibleFeatures = servicePackage.features.slice(0, 4);
---

<article class="checkout-summary" aria-labelledby="checkout-summary-title">
    <div class="checkout-summary-topline">
        <p class="eyebrow">Ringkasan</p>
        <span class="checkout-status-badge">Duitku Sandbox</span>
    </div>

    <h2 class="checkout-title font-display" id="checkout-summary-title">
        {servicePackage.name}
    </h2>
    <p class="checkout-summary-meta">{billingPeriod.label} · CMS Portal Online</p>
    <p class="checkout-description">{servicePackage.description}</p>

    <div class="checkout-price-card" aria-label="Ringkasan harga">
        <span class="checkout-price-label">Total pembayaran</span>
        <div class="checkout-price">
            <span class="checkout-price-value font-display">{formatIdr(price)}</span>
            <span class="checkout-price-period">/{billingPeriod.shortLabel}</span>
        </div>
        <span class="checkout-price-note">Dibayar melalui Duitku Sandbox.</span>
    </div>

    {
        period === "yearly" && (
            <p class="checkout-benefit">
                Hemat 2 bulan + domain .id/.com.
            </p>
        )
    }

    <div class="checkout-includes" aria-label="Termasuk dalam paket">
        <h3 class="checkout-card-heading">Termasuk</h3>
        <ul class="checkout-features">
            {visibleFeatures.map((feature) => <li>{feature}</li>)}
        </ul>
    </div>

    <a class="checkout-summary-link" href="/#pricing">Ganti paket</a>
</article>
