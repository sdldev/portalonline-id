---
const statItems = [
    { value: "95+", label: "Lighthouse score rata-rata" },
    { value: "< 24 jam", label: "Mulai implementasi" },
    { value: "Langsung", label: "Komunikasi dengan developer" },
];
---

<section class="hero" id="hero">
    <div class="container hero-shell">
        <p class="eyebrow reveal">Mitra web untuk redaksi, brand, dan organisasi</p>

        <h1 class="hero-title font-display reveal reveal-delay-1">
            Portal yang siap terbit, siap tumbuh, dan tetap ringan dikelola setiap hari.
        </h1>

        <p class="hero-lead editorial-lead reveal reveal-delay-2">
            Portal Online membangun website berita, company profile, dan kanal publikasi dengan fondasi teknis rapi,
            performa cepat, serta alur editorial yang efisien. Semua dikerjakan langsung bersama developer.
        </p>

        <div class="hero-actions reveal reveal-delay-3">
            <a
                href="https://wa.me/6285783024799?text=Halo%2C%20saya%20ingin%20konsultasi%20gratis%20tentang%20Portal%20Online."
                target="_blank"
                rel="nofollow noopener noreferrer"
                class="btn btn-primary"
            >
                Konsultasi Gratis
            </a>
            <a href="#comparison" class="btn btn-secondary">Lihat Hasil Kerja</a>
        </div>

        <div class="hero-stats reveal reveal-delay-4" aria-label="Ringkasan kualitas layanan">
            {
                statItems.map((item) => (
                    <div class="hero-stat">
                        <span class="hero-stat-value">{item.value}</span>
                        <span class="hero-stat-label">{item.label}</span>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    .hero {
        position: relative;
        padding: 8.8rem 0 4.8rem;
        min-height: min(860px, calc(100svh - 2.6rem));
        display: flex;
        align-items: center;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .hero-shell {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 1.15rem;
        max-width: 74rem;
    }

    .hero-title {
        font-size: clamp(2.8rem, 7vw, 5.1rem);
        line-height: 0.98;
        max-width: 16ch;
    }

    .hero-lead {
        max-width: 66ch;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
        margin-top: 1rem;
    }

    .hero-stats {
        width: 100%;
        margin-top: 2rem;
        display: grid;
        grid-template-columns: 1fr;
        gap: 0;
        border-top: 1px solid rgba(255, 255, 255, 0.12);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .hero-stat {
        padding: 0.9rem 0;
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .hero-stat:last-child {
        border-bottom: none;
    }

    .hero-stat-value {
        font-size: 1.5rem;
        line-height: 1;
        font-weight: 600;
    }

    .hero-stat-label {
        color: var(--color-text-soft);
        font-size: 0.86rem;
    }

    @media (min-width: 820px) {
        .hero-stats {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .hero-stat {
            border-bottom: none;
            border-right: 1px solid rgba(255, 255, 255, 0.08);
            padding: 1.15rem 1rem 1.05rem 0;
        }

        .hero-stat:last-child {
            border-right: none;
        }
    }

    @media (max-width: 767px) {
        .hero {
            padding-top: 7.15rem;
            padding-bottom: 3.4rem;
            min-height: auto;
        }

        .hero-title {
            font-size: clamp(2.15rem, 11vw, 3rem);
            line-height: 1.03;
        }

        .hero-lead {
            font-size: 0.98rem;
        }

        .hero-actions {
            width: 100%;
        }

        .hero-actions .btn {
            width: 100%;
        }
    }
</style>
