---
// WhatsApp number passed via data attribute to the form
---

<!-- Floating Chat Button -->
<button
    class="chat-fab"
    id="chat-fab"
    type="button"
    aria-label="Hubungi via WhatsApp"
    aria-controls="chat-widget"
    aria-expanded="false"
    aria-haspopup="dialog"
>
    <svg
        class="chat-icon"
        xmlns="http://www.w3.org/2000/svg"
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
    >
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
        ></path>
    </svg>
    <svg
        class="close-icon"
        xmlns="http://www.w3.org/2000/svg"
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
    >
        <path d="M18 6 6 18"></path>
        <path d="m6 6 12 12"></path>
    </svg>
</button>

<!-- Chat Widget Panel -->
<div
    class="chat-widget glass"
    id="chat-widget"
    role="dialog"
    aria-modal="false"
    aria-labelledby="chat-widget-title"
    aria-hidden="true"
    hidden
    tabindex="-1"
>
    <div class="chat-header">
        <div class="chat-header-icon">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="currentColor"
            >
                <path
                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                ></path>
            </svg>
        </div>
        <div class="chat-header-text">
            <h4 class="font-display" id="chat-widget-title">Chat WhatsApp</h4>
            <p>Kami siap membantu Anda</p>
        </div>
    </div>

    <form class="chat-form" id="chat-form" data-wa="6285783024799">
        <div class="form-field">
            <label for="sender-name">Nama Anda</label>
            <input
                type="text"
                id="sender-name"
                name="sender"
                required
                placeholder="Masukkan nama Anda"
            />
        </div>
        <div class="form-field">
            <label for="message-content">Pesan</label>
            <textarea
                id="message-content"
                name="message"
                rows="3"
                required
                placeholder="Tulis pesan Anda..."></textarea>
        </div>
        <button type="submit" class="btn btn-whatsapp">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
            >
                <path d="m22 2-7 20-4-9-9-4 20-7Z"></path>
                <path d="M22 2 11 13"></path>
            </svg>
            Kirim ke WhatsApp
        </button>
    </form>
</div>

<noscript>
    <a
        class="chat-noscript-link"
        href="https://wa.me/6285783024799?text=Halo%2C%20saya%20ingin%20konsultasi%20tentang%20Portal%20Online."
        rel="nofollow noopener noreferrer"
        target="_blank"
    >
        Chat via WhatsApp
    </a>
</noscript>

<style>
    /* Floating Action Button */
    .chat-fab {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 3.5rem;
        height: 3.5rem;
        background: linear-gradient(
            135deg,
            rgb(var(--color-primary)),
            rgb(var(--color-accent))
        );
        border-radius: 50%;
        color: white;
        cursor: pointer;
        box-shadow:
            0 4px 20px rgba(var(--color-primary), 0.4),
            0 0 40px rgba(var(--color-primary), 0.2);
        transition: all var(--transition-base);
    }

    .chat-fab:hover {
        transform: scale(1.1);
        box-shadow:
            0 6px 30px rgba(var(--color-primary), 0.5),
            0 0 50px rgba(var(--color-primary), 0.3);
    }

    .chat-fab:active {
        transform: scale(0.95);
    }

    .chat-fab.active {
        background: var(--color-bg-secondary);
        border: 1px solid var(--color-border);
    }

    .close-icon {
        display: none;
    }

    /* Chat Widget Panel */
    .chat-widget {
        position: fixed;
        bottom: 6rem;
        right: 2rem;
        z-index: 999;
        width: 340px;
        max-width: calc(100vw - 2rem);
        border-radius: 1.5rem;
        overflow: hidden;
        opacity: 0;
        visibility: hidden;
        transform: translateY(20px) scale(0.95);
        transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .chat-widget.open {
        opacity: 1;
        visibility: visible;
        transform: translateY(0) scale(1);
    }

    /* Header */
    .chat-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.25rem;
        background: linear-gradient(
            135deg,
            rgba(var(--color-primary), 0.1),
            rgba(var(--color-accent), 0.05)
        );
        border-bottom: 1px solid var(--color-border);
    }

    .chat-header-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.75rem;
        height: 2.75rem;
        background: #25d366;
        border-radius: 0.75rem;
        color: white;
    }

    .chat-header-text h4 {
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 0.125rem;
    }

    .chat-header-text p {
        font-size: 0.75rem;
        color: var(--color-text-muted);
    }

    /* Form */
    .chat-form {
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .chat-form .form-field {
        display: flex;
        flex-direction: column;
        gap: 0.375rem;
    }

    .chat-form label {
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--color-text-muted);
    }

    .chat-form input,
    .chat-form textarea {
        padding: 0.75rem 1rem;
        font-family: inherit;
        font-size: 0.875rem;
        color: var(--color-text);
        background: var(--color-bg-secondary);
        border: 1px solid var(--color-border);
        border-radius: 0.75rem;
        outline: none;
        transition:
            border-color var(--transition-fast),
            box-shadow var(--transition-fast);
        resize: none;
    }

    .chat-form input::placeholder,
    .chat-form textarea::placeholder {
        color: var(--color-text-subtle);
    }

    .chat-form input:focus,
    .chat-form textarea:focus {
        border-color: rgb(var(--color-primary));
        box-shadow: 0 0 0 3px rgba(var(--color-primary), 0.1);
    }

    /* WhatsApp Button */
    .btn-whatsapp {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.875rem 1.5rem;
        background: #25d366;
        color: white;
        font-weight: 700;
        font-size: 0.875rem;
        border-radius: 0.75rem;
        cursor: pointer;
        transition: all var(--transition-base);
        margin-top: 0.5rem;
    }

    .btn-whatsapp:hover {
        background: #20bd5a;
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(37, 211, 102, 0.3);
    }

    .btn-whatsapp:active {
        transform: scale(0.98);
    }

    .chat-noscript-link {
        position: fixed;
        right: 2rem;
        bottom: 2rem;
        z-index: 999;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 2.8rem;
        padding: 0.7rem 1.2rem;
        border-radius: 0.75rem;
        background: #25d366;
        color: #fff;
        font-size: 0.9rem;
        font-weight: 700;
        box-shadow: 0 10px 24px rgba(37, 211, 102, 0.32);
    }

    /* Mobile adjustments */
    @media (max-width: 480px) {
        .chat-fab {
            bottom: 1.5rem;
            right: 1.5rem;
        }

        .chat-widget {
            bottom: 5.5rem;
            right: 1rem;
            left: 1rem;
            width: auto;
            max-width: none;
        }

        .chat-noscript-link {
            right: 1rem;
            left: 1rem;
            bottom: 1.25rem;
        }
    }
</style>

<script>
    (function () {
        type ChatWindow = Window & {
            __chatWidgetInitialized?: boolean;
            __chatOutsideClickHandler?: (e: Event) => void;
            __chatEscapeHandler?: (e: KeyboardEvent) => void;
        };

        const chatWindow = window as ChatWindow;

        // Track if already initialized to prevent duplicates
        if (chatWindow.__chatWidgetInitialized) return;
        chatWindow.__chatWidgetInitialized = true;

        function setupChatWidget() {
            const chatFab = document.getElementById("chat-fab");
            const chatWidget = document.getElementById("chat-widget");
            const chatForm = document.getElementById(
                "chat-form",
            ) as HTMLFormElement | null;

            if (!chatFab || !chatWidget || !chatForm) return;
            const chatFabEl = chatFab;
            const chatWidgetEl = chatWidget;

            // Get WhatsApp number from data attribute
            const whatsappNumber = chatForm.dataset.wa || "";

            const chatIcon = chatFab.querySelector(
                ".chat-icon",
            ) as HTMLElement | null;
            const closeIcon = chatFab.querySelector(
                ".close-icon",
            ) as HTMLElement | null;

            const focusableSelector =
                "a[href], button:not([disabled]), textarea:not([disabled]), input:not([disabled]), select:not([disabled]), [tabindex]:not([tabindex='-1'])";
            let lastFocusedElement: HTMLElement | null = null;

            function getFocusableElements(): HTMLElement[] {
                return Array.from(
                    chatWidgetEl.querySelectorAll<HTMLElement>(focusableSelector),
                ).filter((el) => !el.hasAttribute("disabled"));
            }

            function applyWidgetState(isOpen: boolean) {
                chatWidgetEl.classList.toggle("open", isOpen);
                chatFabEl.classList.toggle("active", isOpen);
                chatFabEl.setAttribute("aria-expanded", String(isOpen));
                chatWidgetEl.setAttribute("aria-hidden", String(!isOpen));

                if (isOpen) {
                    chatWidgetEl.removeAttribute("hidden");
                } else {
                    chatWidgetEl.setAttribute("hidden", "");
                }

                if (chatIcon && closeIcon) {
                    chatIcon.style.display = isOpen ? "none" : "block";
                    closeIcon.style.display = isOpen ? "block" : "none";
                }
            }

            function openWidget() {
                lastFocusedElement =
                    document.activeElement instanceof HTMLElement
                        ? document.activeElement
                        : null;

                applyWidgetState(true);

                requestAnimationFrame(() => {
                    const [firstFocusable] = getFocusableElements();
                    const focusTarget = firstFocusable ?? chatWidgetEl;

                    setTimeout(() => {
                        focusTarget.focus();
                    }, 20);
                });
            }

            function closeWidget(options: { restoreFocus?: boolean } = {}) {
                const { restoreFocus = true } = options;

                applyWidgetState(false);

                if (restoreFocus) {
                    (lastFocusedElement ?? chatFabEl).focus();
                }

                lastFocusedElement = null;
            }

            function toggleWidget(forceClose = false) {
                const shouldOpen = forceClose
                    ? false
                    : !chatWidgetEl.classList.contains("open");

                if (shouldOpen) {
                    openWidget();
                } else {
                    closeWidget();
                }
            }

            applyWidgetState(false);

            // FAB click handler
            chatFabEl.onclick = function (e: Event) {
                e.stopPropagation();
                toggleWidget();
            };

            // Prevent clicks inside widget from closing it
            chatWidgetEl.onclick = function (e: Event) {
                e.stopPropagation();
            };

            // Form submission
            chatForm.onsubmit = function (e: Event) {
                e.preventDefault();

                const senderInput = document.getElementById(
                    "sender-name",
                ) as HTMLInputElement | null;
                const messageInput = document.getElementById(
                    "message-content",
                ) as HTMLTextAreaElement | null;

                const sender = senderInput?.value?.trim();
                const message = messageInput?.value?.trim();

                if (sender && message) {
                    // Format message for WhatsApp
                    const waMessage = "Saya " + sender + ", " + message;
                    const encodedMessage = encodeURIComponent(waMessage);

                    // Open WhatsApp
                    window.open(
                        "https://wa.me/" +
                            whatsappNumber +
                            "?text=" +
                            encodedMessage,
                        "_blank",
                    );

                    // Reset and close
                    chatForm.reset();
                    closeWidget({ restoreFocus: false });
                }
            };

            chatWidgetEl.onkeydown = function (e: KeyboardEvent) {
                if (e.key === "Escape") {
                    e.preventDefault();
                    closeWidget();
                    return;
                }

                if (e.key !== "Tab") return;

                const focusables = getFocusableElements();
                if (focusables.length === 0) {
                    e.preventDefault();
                    chatWidgetEl.focus();
                    return;
                }

                const first = focusables[0];
                const last = focusables[focusables.length - 1];
                const activeElement =
                    document.activeElement instanceof HTMLElement
                        ? document.activeElement
                        : null;

                if (e.shiftKey) {
                    if (activeElement === first || activeElement === chatWidgetEl) {
                        e.preventDefault();
                        last.focus();
                    }
                    return;
                }

                if (activeElement === last) {
                    e.preventDefault();
                    first.focus();
                }
            };

            // Close on outside click
            if (chatWindow.__chatOutsideClickHandler) {
                document.removeEventListener(
                    "click",
                    chatWindow.__chatOutsideClickHandler,
                );
            }

            const handleOutsideClick = function (e: Event) {
                const target = e.target as HTMLElement;
                const isClickInsideWidget = target.closest("#chat-widget");
                const isClickOnFab = target.closest("#chat-fab");

                if (
                    !isClickInsideWidget &&
                    !isClickOnFab &&
                    chatWidgetEl.classList.contains("open")
                ) {
                    closeWidget({ restoreFocus: false });
                }
            };

            chatWindow.__chatOutsideClickHandler = handleOutsideClick;
            document.addEventListener("click", handleOutsideClick);

            if (chatWindow.__chatEscapeHandler) {
                document.removeEventListener(
                    "keydown",
                    chatWindow.__chatEscapeHandler,
                );
            }

            const handleEscape = function (e: KeyboardEvent) {
                if (e.key !== "Escape") return;
                if (!chatWidgetEl.classList.contains("open")) return;

                e.preventDefault();
                closeWidget();
            };

            chatWindow.__chatEscapeHandler = handleEscape;
            document.addEventListener("keydown", handleEscape);
        }

        // Initialize on DOM ready
        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", setupChatWidget);
        } else {
            setupChatWidget();
        }

        // Re-setup after View Transitions (elements get replaced)
        document.addEventListener("astro:after-swap", function () {
            chatWindow.__chatWidgetInitialized = false;
            setupChatWidget();
            chatWindow.__chatWidgetInitialized = true;
        });
    })();
</script>
