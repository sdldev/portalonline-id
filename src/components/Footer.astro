---
import { Image } from "astro:assets";
import footerLogo from "../../public/portalonline-40x40.webp";

const footerLinks = [
    { name: "Beranda", href: "/" },
    { name: "Artikel", href: "/article/" },
    { name: "Tentang", href: "/about/" },
    { name: "Kontak", href: "/contact/" },
];

const legalLinks = [
    { name: "Privasi", href: "/privacy/" },
    { name: "Ketentuan", href: "/terms/" },
    { name: "Sitemap", href: "/sitemap/" },
];
---

<footer class="footer">
    <div class="container footer-main">
        <div class="footer-brand">
            <a href="/" class="footer-logo">
                <Image src={footerLogo} alt="Logo Portal Online" width={40} height={40} loading="lazy" format="webp" />
                <span class="logo-text">Portal Online</span>
            </a>
            <p class="footer-note">Portal Online adalah CMS dirancang khusus untuk membangun website profesional yang rapi, cepat, dan mudah dikelola.</p>
            <a href="mailto:admin@portalonline.id" class="footer-email">admin@portalonline.id</a>
        </div>

        <nav class="footer-nav" aria-label="Navigasi footer">
            {footerLinks.map((link) => <a href={link.href}>{link.name}</a>)}
        </nav>
    </div>

    <div class="container footer-bottom">
        <span class="copyright">© {new Date().getFullYear()} Portal Online. Hak cipta dilindungi.</span>
        <div class="legal-links">
            {legalLinks.map((link) => <a href={link.href}>{link.name}</a>)}
        </div>
    </div>
</footer>

<style>
    .footer {
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        background: transparent;
    }

    .footer-main {
        padding-top: 2.4rem;
        padding-bottom: 2rem;
        display: grid;
        gap: 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .footer-logo {
        display: inline-flex;
        align-items: center;
        gap: 0.72rem;
    }

    .logo-text {
        font-family: var(--font-primary);
        font-size: 1.46rem;
        font-weight: 700;
        letter-spacing: -0.01em;
    }

    .footer-note {
        margin-top: 0.95rem;
        color: var(--color-text-soft);
        line-height: 1.65;
        max-width: 42ch;
    }

    .footer-email {
        margin-top: 0.8rem;
        display: inline-block;
        color: var(--color-text);
        font-size: 0.9rem;
    }

    .footer-email:hover {
        color: rgb(var(--color-primary));
    }

    .footer-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.9rem 1.35rem;
        align-items: flex-start;
    }

    .footer-nav a {
        color: var(--color-text-soft);
        font-size: 0.9rem;
    }

    .footer-nav a:hover {
        color: var(--color-text);
    }

    .footer-bottom {
        padding-top: 1rem;
        padding-bottom: 1.3rem;
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
    }

    .copyright,
    .legal-links a {
        font-size: 0.78rem;
        color: var(--color-text-subtle);
    }

    .legal-links {
        display: flex;
        gap: 1.2rem;
    }

    .legal-links a:hover {
        color: var(--color-text);
    }

    @media (min-width: 900px) {
        .footer-main {
            grid-template-columns: 1fr auto;
            align-items: end;
        }

        .footer-bottom {
            flex-direction: row;
            justify-content: space-between;
            align-items: center;
        }
    }
</style>
